<script>
/* ===== CONFIG ===== */
var QB = {
  realm: 'kin.quickbase.com',
  appId: 'br9kwm8bk',
  token: 'b6teb3_p3bs_0_bzh28isbyba5yh9ujb73hqthh5',
  ticketsTable: 'bstdqwrkg',
  arrivyTable: 'bvbqgs5yc'
};

var TICKET_FIELDS = [3,1,4,19,20,23,26,27,36,37,41,42,44,47,50,52,59,67,85,87,88,91,95,100,108,109,134,163];
var ARRIVY_FIELDS = [3,56,85,97,107,115,117,137,146,268,270];

/* ===== HELPERS ===== */
function titleCase(str) { if(!str) return ''; return String(str).replace(/\w\S*/g, function(w){return w.charAt(0).toUpperCase()+w.substr(1).toLowerCase();}); }
function escapeHtml(str) { if(!str) return ''; return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function qbv(record, fieldId) { if(!record||!record[fieldId]) return null; var v=record[fieldId]; if(typeof v==='object'&&v!==null){if(v.value!==undefined){var val=v.value;if(typeof val==='object'&&val!==null)return val.name||val.email||JSON.stringify(val);return val;}return v.name||v.email||JSON.stringify(v);}return v; }
function qbUserName(record, fieldId) { if(!record||!record[fieldId]) return ''; var v=record[fieldId]; if(typeof v==='object'&&v!==null){if(v.value&&typeof v.value==='object')return v.value.name||v.value.email||'';if(v.value!==undefined)return String(v.value);return v.name||v.email||'';}return String(v); }
function fmtDate(d) { if(!d) return '-'; var dt=new Date(d+'T12:00:00'); return isNaN(dt)?d:dt.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }
function fmtDateTime(d) { if(!d) return '-'; var dt=new Date(d); return isNaN(dt)?d:dt.toLocaleDateString('en-US',{month:'short',day:'numeric'})+' '+dt.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'}); }
function todayStr() { var d=new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }

function getHeaders() {
  return { 'QB-Realm-Hostname': QB.realm, 'Authorization': 'QB-USER-TOKEN ' + QB.token, 'Content-Type': 'application/json' };
}

function apiQuery(tableId, fields, where, top) {
  var body = { from: tableId, select: fields };
  if (where) body.where = where;
  if (top) body.options = { top: top };
  return fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST', headers: getHeaders(), body: JSON.stringify(body)
  }).then(function(resp) {
    if (!resp.ok) throw new Error('API error: ' + resp.status);
    return resp.json();
  }).then(function(json) { return json.data || []; });
}

/* ===== STATE ===== */
var allTickets = [];
var currentView = 'summary';
var selectedTicket = null;
var searchTerm = '';
var currentUser = '';
var currentUserDetected = false;
var filterScope = 'all';
var filterPriority = 'all';
var listContext = null;
var activePivot = 'assigned';

/* ===== AUTO-DETECT CURRENT USER ===== */
function detectCurrentUser() {
  // Use QB Classic API_GetUserInfo via session cookie (works when embedded in QB)
  return fetch('https://' + QB.realm + '/db/main?a=API_GetUserInfo&fmt=structured', {
    method: 'GET',
    credentials: 'include'
  })
  .then(function(resp) {
    if (!resp.ok) throw new Error('Not in QB context');
    return resp.text();
  })
  .then(function(xml) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(xml, 'text/xml');
    var errcode = doc.querySelector('errcode');
    if (errcode && errcode.textContent !== '0') throw new Error('QB auth error');
    var firstName = doc.querySelector('firstName');
    var lastName = doc.querySelector('lastName');
    if (firstName && lastName) {
      var name = firstName.textContent.trim() + ' ' + lastName.textContent.trim();
      if (name.trim()) {
        currentUser = name.trim();
        currentUserDetected = true;
        filterScope = 'mine';
        console.log('Auto-detected user: ' + currentUser);
        return;
      }
    }
    throw new Error('Could not parse user info');
  })
  .catch(function(e) {
    console.log('User auto-detect failed (not in QB context?): ' + e.message);
    // Fall back: check localStorage
    var saved = localStorage.getItem('qbskin_user');
    if (saved) {
      currentUser = saved;
      filterScope = 'mine';
    }
  });
}

/* ===== DATA LOADING ===== */
function loadAllTickets() {
  showLoading(true);
  apiQuery(QB.ticketsTable, TICKET_FIELDS,
    "{'91'.XEX.'Completed'}AND{'91'.XEX.'Closed'}AND{'91'.XEX.'Complete'}AND{'166'.XEX.'true'}", 500)
  .then(function(data) {
    allTickets = data;
    extractUsers();
    updateKPIs();
    renderFilters();
    renderSummary();
    showLoading(false);
  })
  .catch(function(e) {
    console.error('Load error:', e);
    showError('Failed to load tickets: ' + e.message);
    showLoading(false);
  });
}

/* ===== USER LIST ===== */
var allUsers = [];
function extractUsers() {
  var names = {};
  allTickets.forEach(function(t) {
    var creator = qbUserName(t, 4);
    var assignee = qbv(t, 67) || '';
    if (creator) names[creator.trim()] = true;
    if (assignee) names[String(assignee).trim()] = true;
  });
  allUsers = Object.keys(names).filter(function(n){return n;}).sort();
}

function showUserModal() {
  var list = document.getElementById('userList');
  var html = '';
  allUsers.forEach(function(name) {
    var initials = name.split(' ').map(function(w){return w[0]||'';}).join('').substring(0, 2).toUpperCase();
    var sel = name === currentUser ? ' selected' : '';
    html += '<button class="user-option' + sel + '" onclick="selectUser(\'' + escapeHtml(name.replace(/'/g, "\\'")) + '\')">' +
      '<span class="user-avatar">' + escapeHtml(initials) + '</span>' +
      escapeHtml(name) + '</button>';
  });
  if (!allUsers.length) html = '<div class="empty-state">No users found.</div>';
  list.innerHTML = html;
  document.getElementById('userModalOverlay').classList.add('show');
  document.getElementById('userModal').classList.add('show');
}

function hideUserModal() {
  document.getElementById('userModalOverlay').classList.remove('show');
  document.getElementById('userModal').classList.remove('show');
}

function selectUser(name) {
  currentUser = name;
  localStorage.setItem('qbskin_user', name);
  filterScope = 'mine';
  hideUserModal();
  updateKPIs(); renderFilters(); renderSummary();
}

/* ===== URGENCY BUCKETING ===== */
function getTicketDue(t) { return qbv(t, 95) || qbv(t, 52) || ''; }

function getBucket(t) {
  var due = getTicketDue(t);
  if (!due) return 'futuredue';
  var dueDate = due.split('T')[0];
  var today = todayStr();
  if (dueDate < today) return 'pastdue';
  if (dueDate === today) return 'duetoday';
  return 'futuredue';
}

/* ===== COMPUTED STATUS ===== */
function getComputedStatus(t) {
  var bucket = getBucket(t);
  if (bucket === 'pastdue') return { label: 'Past Due', cls: 'pastdue' };
  if (bucket === 'duetoday') return { label: 'Due Today', cls: 'duetoday' };
  // Future due: check raw status for "follow up"
  var rawStatus = (qbv(t, 91) || '').toLowerCase();
  if (rawStatus.indexOf('follow') >= 0) return { label: 'Follow Up Scheduled', cls: 'followupscheduled' };
  return { label: 'On Track', cls: 'ontrack' };
}

/* ===== FILTERING ===== */
function getFilteredTickets() {
  var tickets = allTickets;

  if (filterScope === 'mine' && currentUser) {
    var cu = currentUser.toLowerCase();
    tickets = tickets.filter(function(t) {
      var creator = qbUserName(t, 4).toLowerCase();
      var assignee = (qbv(t, 67) || '').toString().toLowerCase();
      return creator.indexOf(cu) >= 0 || cu.indexOf(creator.split(' ')[0]) >= 0 ||
             assignee.indexOf(cu) >= 0 || cu.indexOf(assignee.split(' ')[0]) >= 0;
    });
  }

  if (filterPriority !== 'all') {
    tickets = tickets.filter(function(t) {
      var p = (qbv(t, 87) || 'normal').toLowerCase();
      return p.indexOf(filterPriority) >= 0;
    });
  }

  if (searchTerm) {
    var q = searchTerm.toLowerCase();
    tickets = tickets.filter(function(t) {
      var title = (qbv(t, 19) || '').toLowerCase();
      var project = (qbv(t, 27) || '').toLowerCase();
      var assignee = (qbv(t, 67) || '').toString().toLowerCase();
      var creator = qbUserName(t, 4).toLowerCase();
      return title.indexOf(q) >= 0 || project.indexOf(q) >= 0 || assignee.indexOf(q) >= 0 || creator.indexOf(q) >= 0;
    });
  }

  return tickets;
}

/* ===== KPI CALCULATION ===== */
function updateKPIs() {
  var tickets = getFilteredTickets();
  var overdue = 0, dueToday = 0, futureDue = 0;
  tickets.forEach(function(t) {
    var b = getBucket(t);
    if (b === 'pastdue') overdue++;
    else if (b === 'duetoday') dueToday++;
    else futureDue++;
  });
  document.getElementById('kpiAll').textContent = tickets.length;
  document.getElementById('kpiOverdue').textContent = overdue;
  document.getElementById('kpiDueToday').textContent = dueToday;
  document.getElementById('kpiFutureDue').textContent = futureDue;

  // Update drawer badge
  var badge = document.getElementById('ticketBadge');
  if (badge) {
    if (overdue > 0) { badge.textContent = overdue; badge.style.display = 'inline-flex'; }
    else { badge.style.display = 'none'; }
  }

  // Make KPI chips tappable (overdue + due today drill down)
  var kpiChips = document.querySelectorAll('.kpi-chip');
  kpiChips.forEach(function(chip) {
    var kpi = chip.getAttribute('data-kpi');
    if (kpi === 'overdue' || kpi === 'duetoday') {
      chip.style.cursor = 'pointer';
      chip.onclick = function() { drillDownKPI(kpi); };
    } else {
      chip.style.cursor = 'default';
      chip.onclick = null;
    }
  });
}

function drillDownKPI(kpi) {
  var bucketMap = { overdue: 'pastdue', duetoday: 'duetoday' };
  var labelMap = { overdue: 'Past Due', duetoday: 'Due Today' };
  listContext = { userName: null, bucket: bucketMap[kpi], tableType: 'kpi', kpiLabel: labelMap[kpi] };
  navigateView('list');
  renderTicketList();
}

/* ===== FILTERS RENDER ===== */
function renderFilters() {
  var r1 = document.getElementById('filterRow1');
  var mineLabel = currentUserDetected ? 'Mine' : (currentUser ? 'Mine (' + currentUser.split(' ')[0] + ')' : 'Mine');
  r1.innerHTML =
    '<div class="filter-row">' +
    '<button class="qf-chip' + (filterScope === 'all' ? ' active' : '') + '" onclick="setScope(\'all\')">All</button>' +
    '<button class="qf-chip' + (filterScope === 'mine' ? ' active' : '') + '" onclick="setScope(\'mine\')">' + escapeHtml(mineLabel) + '</button>' +
    '<button class="qf-chip" onclick="showUserModal()">Select User</button>' +
    '</div>';

  var r2 = document.getElementById('filterRow2');
  r2.innerHTML =
    '<div class="filter-row">' +
    '<button class="qf-chip' + (filterPriority === 'all' ? ' active' : '') + '" onclick="setPriority(\'all\')">All</button>' +
    '<button class="qf-chip' + (filterPriority === 'high' ? ' active' : '') + '" onclick="setPriority(\'high\')">High</button>' +
    '<button class="qf-chip' + (filterPriority === 'medium' ? ' active' : '') + '" onclick="setPriority(\'medium\')">Medium</button>' +
    '<button class="qf-chip' + (filterPriority === 'low' ? ' active' : '') + '" onclick="setPriority(\'low\')">Low</button>' +
    '</div>';
}

function setScope(val) {
  if (val === 'mine' && !currentUser) { showUserModal(); return; }
  filterScope = val;
  updateKPIs(); renderFilters(); renderSummary();
}

function setPriority(val) {
  filterPriority = val;
  updateKPIs(); renderFilters(); renderSummary();
}

/* ===== SUMMARY TABLES (Level 0) ===== */
function setPivot(pivot) {
  activePivot = pivot;
  document.querySelectorAll('.pivot-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelector('.pivot-btn[onclick*="' + pivot + '"]').classList.add('active');
  renderSummary();
}

function getGroupKey(t, pivot) {
  if (pivot === 'assigned') return (qbv(t, 67) || '').toString().trim() || 'Unassigned';
  if (pivot === 'requested') return qbUserName(t, 4).trim() || 'Unknown';
  if (pivot === 'issue') return (qbv(t, 50) || '').toString().trim() || 'No Issue';
  if (pivot === 'category') return (qbv(t, 47) || '').toString().trim() || 'No Category';
  if (pivot === 'state') {
    // QB address field returns object — extract state
    var addr = t[41];
    if (addr && typeof addr === 'object') {
      var v = addr.value;
      if (v && typeof v === 'object') return (v.state || v.province || '').trim() || 'No State';
      if (typeof v === 'string') return v; // fallback
    }
    return (qbv(t, 41) || '').toString().trim() || 'No State';
  }
  if (pivot === 'coordinator') return (qbv(t, 85) || '').toString().trim() || 'No Coordinator';
  if (pivot === 'status') return (qbv(t, 36) || '').toString().trim() || 'No Status';
  if (pivot === 'epc') return (qbv(t, 37) || '').toString().trim() || 'No EPC';
  if (pivot === 'disposition') return (qbv(t, 108) || '').toString().trim() || 'Open';
  if (pivot === 'blocker') return (qbv(t, 163) || false) ? 'Blocker' : 'Non-Blocker';
  if (pivot === 'closer') return (qbv(t, 44) || '').toString().trim() || 'No Closer';
  return 'Unknown';
}

var PIVOT_LABELS = {
  assigned: 'ASSIGNED TO', requested: 'REQUESTED BY', issue: 'TICKET ISSUE',
  category: 'CATEGORY', state: 'STATE', coordinator: 'COORDINATOR',
  status: 'PROJECT STATUS', epc: 'EPC', disposition: 'DISPOSITION',
  blocker: 'BLOCKER', closer: 'CLOSER'
};
var PIVOT_COL_HEADERS = {
  assigned: 'Name', requested: 'Name', issue: 'Issue', category: 'Category',
  state: 'State', coordinator: 'Coordinator', status: 'Status', epc: 'EPC',
  disposition: 'Disposition', blocker: 'Type', closer: 'Closer'
};

function renderSummary() {
  var tickets = getFilteredTickets();
  var container = document.getElementById('summaryContent');

  if (!tickets.length) {
    container.innerHTML = '<div class="empty-state">No open tickets match the current filters.</div>';
    return;
  }

  var dataMap = {};
  tickets.forEach(function(t) {
    var key = getGroupKey(t, activePivot);
    var bucket = getBucket(t);
    if (!dataMap[key]) dataMap[key] = { pastdue: [], duetoday: [], futuredue: [], all: [] };
    dataMap[key][bucket].push(t);
    dataMap[key].all.push(t);
  });

  container.innerHTML = buildSummaryTable(PIVOT_LABELS[activePivot] || 'GROUP', dataMap, activePivot, PIVOT_COL_HEADERS[activePivot] || 'Name');
}

function buildSummaryTable(label, dataMap, tableType, colHeader) {
  var sorted = Object.keys(dataMap).sort(function(a, b) { return dataMap[b].all.length - dataMap[a].all.length; });

  var totalPD = 0, totalDT = 0, totalFD = 0, totalAll = 0;
  sorted.forEach(function(name) {
    totalPD += dataMap[name].pastdue.length;
    totalDT += dataMap[name].duetoday.length;
    totalFD += dataMap[name].futuredue.length;
    totalAll += dataMap[name].all.length;
  });

  var tableId = 'summaryTable_' + tableType;
  var html = '<div class="section-label" onclick="toggleSummaryTable(\'' + tableId + '\')">' +
    '<span>' + label + '</span><span class="collapse-arrow" id="arrow_' + tableId + '">&#9660;</span></div>';
  html += '<div class="summary-table-wrap" id="' + tableId + '"><table class="summary-table">';
  html += '<thead><tr><th>' + (colHeader || 'Name') + '</th><th>Past Due</th><th>Today</th><th>Future</th><th>Total</th></tr></thead>';
  html += '<tbody>';

  sorted.forEach(function(name) {
    var d = dataMap[name];
    var pd = d.pastdue.length;
    var dt = d.duetoday.length;
    var fd = d.futuredue.length;
    var tot = d.all.length;
    var eName = escapeHtml(name);
    var safeName = name.replace(/'/g, "\\'");

    html += '<tr>';
    html += '<td title="' + eName + '">' + eName + '</td>';
    html += '<td class="' + (pd > 0 ? 'past-due tappable' : '') + '"' +
      (pd > 0 ? ' onclick="drillDown(\'' + safeName + '\',\'pastdue\',\'' + tableType + '\')"' : '') +
      '>' + (pd || '-') + '</td>';
    html += '<td class="' + (dt > 0 ? 'due-today tappable' : '') + '"' +
      (dt > 0 ? ' onclick="drillDown(\'' + safeName + '\',\'duetoday\',\'' + tableType + '\')"' : '') +
      '>' + (dt || '-') + '</td>';
    html += '<td class="' + (fd > 0 ? 'tappable' : '') + '"' +
      (fd > 0 ? ' onclick="drillDown(\'' + safeName + '\',\'futuredue\',\'' + tableType + '\')"' : '') +
      '>' + (fd || '-') + '</td>';
    html += '<td class="' + (tot > 0 ? 'tappable' : '') + '"' +
      (tot > 0 ? ' onclick="drillDown(\'' + safeName + '\',\'all\',\'' + tableType + '\')"' : '') +
      '>' + tot + '</td>';
    html += '</tr>';
  });

  html += '<tr class="totals-row">';
  html += '<td>Totals</td>';
  html += '<td class="' + (totalPD > 0 ? 'past-due' : '') + '">' + (totalPD || '-') + '</td>';
  html += '<td class="' + (totalDT > 0 ? 'due-today' : '') + '">' + (totalDT || '-') + '</td>';
  html += '<td>' + (totalFD || '-') + '</td>';
  html += '<td>' + totalAll + '</td>';
  html += '</tr>';

  html += '</tbody></table></div>';
  return html;
}

/* ===== DRILL DOWN (Level 1) ===== */
function drillDown(userName, bucket, tableType) {
  listContext = { userName: userName, bucket: bucket, tableType: tableType };
  navigateView('list');
  renderTicketList();
}

function renderTicketList() {
  var ctx = listContext;
  if (!ctx) return;
  var container = document.getElementById('ticketListContent');
  var tickets = getFilteredTickets();
  var filtered;

  if (ctx.tableType === 'kpi') {
    filtered = tickets.filter(function(t) { return getBucket(t) === ctx.bucket; });
  } else {
    filtered = tickets.filter(function(t) {
      var name = getGroupKey(t, ctx.tableType);
      return name === ctx.userName;
    });
    if (ctx.bucket !== 'all') {
      filtered = filtered.filter(function(t) { return getBucket(t) === ctx.bucket; });
    }
  }

  if (!filtered.length) {
    container.innerHTML = '<div class="empty-state">No tickets found.</div>';
    return;
  }

  if (ctx.bucket === 'all') {
    var groups = { pastdue: [], duetoday: [], futuredue: [] };
    filtered.forEach(function(t) { groups[getBucket(t)].push(t); });

    var html = '';
    var cfg = [
      { key: 'pastdue', label: 'Past Due', cls: 'overdue' },
      { key: 'duetoday', label: 'Due Today', cls: 'today' },
      { key: 'futuredue', label: 'Future Due', cls: 'futuredue' }
    ];
    cfg.forEach(function(g) {
      if (!groups[g.key].length) return;
      var groupId = 'group_' + g.key;
      html += '<div class="group-header ' + g.cls + '" onclick="toggleGroupCards(\'' + groupId + '\')">' +
        '<span class="collapse-arrow" id="arrow_' + groupId + '">&#9660;</span> ' + g.label +
        ' <span class="group-count">' + groups[g.key].length + '</span></div>';
      html += '<div class="group-cards" id="' + groupId + '">';
      groups[g.key].forEach(function(t) { html += renderTicketCard(t); });
      html += '</div>';
    });
    container.innerHTML = html;
  } else {
    var bucketLabels = { pastdue: 'Past Due', duetoday: 'Due Today', futuredue: 'Future Due' };
    var bucketCls = { pastdue: 'overdue', duetoday: 'today', futuredue: 'futuredue' };
    var groupId = 'group_single';
    var html = '<div class="group-header ' + (bucketCls[ctx.bucket] || '') + '" onclick="toggleGroupCards(\'' + groupId + '\')">' +
      '<span class="collapse-arrow" id="arrow_' + groupId + '">&#9660;</span> ' +
      (bucketLabels[ctx.bucket] || 'Tickets') +
      ' <span class="group-count">' + filtered.length + '</span></div>';
    html += '<div class="group-cards" id="' + groupId + '">';
    filtered.forEach(function(t) { html += renderTicketCard(t); });
    html += '</div>';
    container.innerHTML = html;
  }
}

function renderTicketCard(t) {
  var title = titleCase(qbv(t, 19) || qbv(t, 50) || 'Untitled');
  var priority = (qbv(t, 87) || 'Normal').toLowerCase();
  var category = qbv(t, 47) || '';
  var projectName = qbv(t, 27) || '';
  var assignee = (qbv(t, 67) || '').toString().trim();
  var due = getTicketDue(t);
  var dueStr = fmtDate(due ? due.split('T')[0] : '');
  var created = qbv(t, 23) || qbv(t, 1) || '';
  var bucket = getBucket(t);
  var computed = getComputedStatus(t);

  var borderCls = 'border-normal';
  if (priority.indexOf('high') >= 0) borderCls = 'border-high';
  else if (priority.indexOf('medium') >= 0 || priority.indexOf('med') >= 0) borderCls = 'border-medium';
  else if (priority.indexOf('low') >= 0) borderCls = 'border-low';

  var pills = '<span class="status-pill ' + computed.cls + '">' + escapeHtml(computed.label) + '</span>';
  var dataIdx = allTickets.indexOf(t);

  // Days past due badge
  var pastDueBadge = '';
  if (due && bucket === 'pastdue') {
    var dueDate = new Date(due.split('T')[0] + 'T12:00:00');
    var todayDate = new Date(todayStr() + 'T12:00:00');
    var diffDays = Math.floor((todayDate - dueDate) / (1000 * 60 * 60 * 24));
    if (diffDays > 0) {
      pastDueBadge = '<span class="past-due-badge">' + diffDays + 'd overdue</span>';
    }
  }

  // Ticket age (days since created)
  var ageBadge = '';
  if (created) {
    var createdDate = new Date(created);
    var now = new Date(todayStr() + 'T12:00:00');
    var ageDays = Math.floor((now - createdDate) / (1000 * 60 * 60 * 24));
    if (ageDays > 0) {
      ageBadge = '<span style="font-size:10px;color:' + (ageDays > 14 ? 'var(--danger)' : ageDays > 7 ? 'var(--warning)' : 'var(--muted)') + ';font-weight:600">' + ageDays + 'd old</span>';
    }
  }

  return '<div class="record-card ' + borderCls + (bucket === 'pastdue' ? ' overdue-tint' : '') + '"' +
    ' onclick="openTicketDetail(' + dataIdx + ')">' +
    '<div class="card-header"><div class="card-title">' + escapeHtml(title) + '</div>' +
    '<div class="card-pills">' + pills + '</div></div>' +
    (assignee ? '<div style="font-size:12px;font-weight:600;color:var(--text);margin-bottom:2px">' + escapeHtml(assignee) + '</div>' : '') +
    '<div class="card-sub"><span>' + dueStr + '</span>' +
    (pastDueBadge ? '<span>' + pastDueBadge + '</span>' : '') +
    (ageBadge ? '<span>' + ageBadge + '</span>' : '') +
    (category ? '<span>' + escapeHtml(category) + '</span>' : '') +
    (projectName ? '<span>' + escapeHtml(projectName) + '</span>' : '') +
    '</div></div>';
}

/* ===== TICKET DETAIL (Level 2) ===== */
function openTicketDetail(idx) {
  selectedTicket = allTickets[idx];
  if (!selectedTicket) return;
  navigateView('detail');
  renderTicketDetail(selectedTicket);
}

function renderTicketDetail(t) {
  var container = document.getElementById('ticketDetailContent');
  var rid = qbv(t, 3);
  var title = titleCase(qbv(t, 19) || 'Untitled');
  var desc = qbv(t, 20) || '';
  var rawStatus = qbv(t, 91) || 'Open';
  var computed = getComputedStatus(t);
  var priority = qbv(t, 87) || 'Normal';
  var category = qbv(t, 47) || '';
  var issue = qbv(t, 50) || '';
  var assignee = qbv(t, 67) || '';
  var creator = qbUserName(t, 4);
  var projectName = qbv(t, 27) || '';
  var due = getTicketDue(t);
  var created = qbv(t, 23) || qbv(t, 1) || '';
  var coordinator = qbv(t, 85) || '';
  var disposition = qbv(t, 108) || '';
  var projectId = qbv(t, 26);
  var viewUrl = qbv(t, 109);
  var qbUrl = viewUrl || ('https://kin.quickbase.com/db/bstdqwrkg?a=dr&rid=' + rid);

  var statusHtml = '<span class="status-pill ' + computed.cls + '" style="font-size:13px;padding:4px 10px;">' + escapeHtml(computed.label) + '</span>';

  var html = '<div class="detail-card">' +
    '<div class="detail-title">' + escapeHtml(title) + '</div>' +
    (desc ? '<div class="detail-desc">' + escapeHtml(desc) + '</div>' : '') +
    '<div class="card-row"><span class="label">Status</span><span class="val">' + statusHtml + '</span></div>' +
    '<div class="card-row"><span class="label">QB Status</span><span class="val">' + escapeHtml(rawStatus) + '</span></div>' +
    '<div class="card-row"><span class="label">Priority</span><span class="val">' + escapeHtml(priority) + '</span></div>' +
    '<div class="card-row"><span class="label">Category</span><span class="val">' + escapeHtml(category || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Ticket Issue</span><span class="val">' + escapeHtml(issue || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Assigned To</span><span class="val">' + escapeHtml(assignee || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Requested By</span><span class="val">' + escapeHtml(creator || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Project</span><span class="val">' + escapeHtml(projectName || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Due Date</span><span class="val">' + fmtDate(due ? due.split('T')[0] : '') + '</span></div>' +
    '<div class="card-row"><span class="label">Created</span><span class="val">' + fmtDateTime(created) + '</span></div>' +
    '<div class="card-row"><span class="label">Coordinator</span><span class="val">' + escapeHtml(coordinator || '-') + '</span></div>' +
    '<div class="card-row"><span class="label">Disposition</span><span class="val">' + escapeHtml(disposition || '-') + '</span></div>' +
    '<a class="qb-open-btn" href="' + escapeHtml(qbUrl) + '" target="_blank">' +
      '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>' +
      'Open in QuickBase</a>' +
    '</div>';

  if (projectId) {
    html += '<div class="related-header" onclick="toggleRelatedTasks()">' +
      '<span class="arrow" id="relatedArrow">&#9654;</span> Related Field Tasks' +
      '</div><div class="related-tasks-list" id="relatedTasksList">' +
      '<div class="empty-state">Loading tasks...</div></div>';
  }

  container.innerHTML = html;

  if (projectId) {
    apiQuery(QB.arrivyTable, ARRIVY_FIELDS, "{'6'.EX.'" + projectId + "'}", 50)
    .then(function(tasks) {
      var list = document.getElementById('relatedTasksList');
      if (!list) return;
      if (tasks.length === 0) { list.innerHTML = '<div class="empty-state">No related field tasks</div>'; return; }
      var sorted = tasks.sort(function(a, b) { return (qbv(b, 115) || '').localeCompare(qbv(a, 115) || ''); });
      var thtml = '';
      sorted.forEach(function(task) {
        var tmpl = qbv(task, 56) || 'Unknown';
        var schedDate = qbv(task, 115);
        var taskStatus = qbv(task, 85) || '';
        var crew = qbv(task, 268) || '';
        var dateStr = schedDate ? fmtDate(schedDate.split('T')[0]) : '';
        var statusCls = taskStatus.toLowerCase().replace(/\s+/g, '');
        thtml += '<div class="record-card" style="cursor:pointer">' +
          '<div class="card-header"><div class="card-title">' + escapeHtml(tmpl) + '</div>' +
          '<span class="status-pill ' + statusCls + '">' + escapeHtml(taskStatus) + '</span></div>' +
          '<div class="card-sub">' +
          (dateStr ? '<span>' + dateStr + '</span>' : '') +
          (crew ? '<span>' + escapeHtml(crew) + '</span>' : '') +
          '</div></div>';
      });
      list.innerHTML = thtml;
      list.classList.add('open');
      var arrow = document.getElementById('relatedArrow');
      if (arrow) arrow.classList.add('open');
    })
    .catch(function() {
      var list = document.getElementById('relatedTasksList');
      if (list) list.innerHTML = '<div class="empty-state">Could not load related tasks</div>';
    });
  }
}

function toggleRelatedTasks() {
  var list = document.getElementById('relatedTasksList');
  var arrow = document.getElementById('relatedArrow');
  if (list) list.classList.toggle('open');
  if (arrow) arrow.classList.toggle('open');
}

function toggleSummaryTable(tableId) {
  var table = document.getElementById(tableId);
  var arrow = document.getElementById('arrow_' + tableId);
  if (table) table.classList.toggle('collapsed');
  if (arrow) arrow.classList.toggle('collapsed');
}

function toggleGroupCards(groupId) {
  var group = document.getElementById(groupId);
  var arrow = document.getElementById('arrow_' + groupId);
  if (group) group.classList.toggle('collapsed');
  if (arrow) arrow.classList.toggle('collapsed');
}

/* ===== VIEW NAVIGATION ===== */
function navigateView(view) {
  currentView = view;
  var backBtn = document.getElementById('backBtn');
  var titleEl = document.getElementById('headerTitle');
  var kpiStrip = document.getElementById('kpiStrip');
  var filterSection = document.getElementById('filterSection');

  document.querySelectorAll('.view-panel').forEach(function(p) { p.classList.remove('active'); });

  if (view === 'summary') {
    document.getElementById('viewSummary').classList.add('active');
    backBtn.style.display = 'none';
    titleEl.textContent = 'Tickets';
    kpiStrip.style.display = '';
    filterSection.style.display = '';
  } else if (view === 'list') {
    document.getElementById('viewTicketList').classList.add('active');
    backBtn.style.display = 'flex';
    var bucketLabels = { pastdue: 'Past Due', duetoday: 'Due Today', futuredue: 'Future Due', all: 'All' };
    if (listContext && listContext.tableType === 'kpi') {
      titleEl.textContent = listContext.kpiLabel || 'Tickets';
    } else {
      titleEl.textContent = (listContext ? listContext.userName + ' \u2014 ' + (bucketLabels[listContext.bucket] || 'All') : 'Tickets');
    }
    kpiStrip.style.display = 'none';
    filterSection.style.display = 'none';
  } else if (view === 'detail') {
    document.getElementById('viewTicketDetail').classList.add('active');
    backBtn.style.display = 'flex';
    titleEl.textContent = titleCase(qbv(selectedTicket, 19) || 'Ticket Detail');
    kpiStrip.style.display = 'none';
    filterSection.style.display = 'none';
  }

  document.getElementById('scrollArea').scrollTop = 0;
}

function goBack() {
  if (currentView === 'detail') {
    if (listContext) { navigateView('list'); renderTicketList(); }
    else { navigateView('summary'); }
  } else if (currentView === 'list') {
    navigateView('summary');
  }
}

/* ===== DRAWER ===== */
function toggleDrawer() {
  var drawer = document.getElementById('sideDrawer');
  var overlay = document.getElementById('drawerOverlay');
  var isOpen = drawer.classList.contains('open');
  if (isOpen) { drawer.classList.remove('open'); overlay.classList.remove('open'); }
  else { drawer.classList.add('open'); overlay.classList.add('open'); }
}

/* ===== SEARCH ===== */
function toggleSearch() {
  var bar = document.getElementById('searchBar');
  var isOpen = bar.classList.contains('open');
  bar.classList.toggle('open');
  if (!isOpen) {
    document.getElementById('searchInput').focus();
  } else {
    document.getElementById('searchInput').value = '';
    searchTerm = '';
    if (currentView === 'summary') { updateKPIs(); renderSummary(); }
    else if (currentView === 'list') { renderTicketList(); }
  }
}

function handleSearch(val) {
  searchTerm = val.trim();
  if (currentView === 'summary') { updateKPIs(); renderSummary(); }
  else if (currentView === 'list') { renderTicketList(); }
}

/* ===== LOADING/ERROR ===== */
function showLoading(show) {
  document.getElementById('loadingOverlay').classList.toggle('hidden', !show);
}

function showError(msg) {
  var banner = document.getElementById('errorBanner');
  document.getElementById('errorText').textContent = msg;
  banner.classList.add('show');
}

/* ===== INIT ===== */
document.addEventListener('DOMContentLoaded', function() {
  // Detect current user first, then load tickets
  detectCurrentUser().then(function() {
    renderFilters();
    loadAllTickets();
  });
});
</script>
