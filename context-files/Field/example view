  rtrReadyCount: 217
};

var SELECT_FIELDS = [3, F.scheduledDateTime, F.customerFirstName, F.customerLastName, F.taskStatus, F.templateName, F.taskUrl, F.enrouteStatus, F.startedStatus, F.submittedDateTime, F.techCompleteDateTime, F.enrouteName, F.crew, F.assignedCrew, F.installComplete, F.kw, F.relatedProject, F.rtrStatus, F.rtrReadyCount];

/* ===== HELPERS ===== */
function qbv(rec, fid) { return rec[fid] ? rec[fid].value : null; }
function escapeHtml(str) { if(!str) return ''; return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function formatDate(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function formatTime(ds) { if(!ds) return '--:--'; var d=new Date(ds); return d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',hour12:true}); }
function getInitials(name) { return name.split(' ').map(function(n){return n[0]||'';}).join('').toUpperCase().slice(0,2); }
function fmtDateTime(ds) { if(!ds) return '-'; var d=new Date(ds); if(isNaN(d)) return ds; return d.toLocaleDateString('en-US',{month:'short',day:'numeric'})+' '+d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',hour12:true}); }
function qbStr(rec, fid) {
  if (!rec || !rec[fid]) return '';
  var v = rec[fid];
  if (typeof v === 'object' && v !== null) {
    if (v.value !== undefined) {
      var val = v.value;
      if (typeof val === 'object' && val !== null) return val.name || val.email || String(val) || '';
      return val ? String(val) : '';
    }
    return v.name || v.email || String(v) || '';
  }
  return v ? String(v) : '';
}
function getCrewName(t) { return qbStr(t, F.crew) || qbStr(t, F.assignedCrew) || qbStr(t, F.enrouteName) || ''; }

/* ===== STATE ===== */
var allTasks = [];
var activePreset = 'today';
var activeTab = 'leaderboard';
var searchTerm = '';

/* ===== DATE RANGES ===== */
function getDateRange(preset) {
  var today = new Date();
  today.setHours(0,0,0,0);
  var from = new Date(today);
  var to = new Date(today);
  to.setHours(23,59,59,999);

  switch(preset) {
    case 'yesterday':
      from.setDate(from.getDate()-1);
      to = new Date(from); to.setHours(23,59,59,999);
      break;
    case 'week':
      var day=from.getDay(); from.setDate(from.getDate()-(day===0?6:day-1));
      break;
    case 'month':
      from.setDate(1);
      break;
    case '30days':
      from.setDate(from.getDate()-30);
      break;
  }
  return { from: from, to: to };
}

/* ===== API ===== */
function apiQuery(where) {
  return fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST',
    headers: {
      'QB-Realm-Hostname': QB.realm,
      'Authorization': 'QB-USER-TOKEN ' + QB.token,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      from: QB.arrivyTable,
      where: where,
      select: SELECT_FIELDS,
      sortBy: [{ fieldId: F.scheduledDateTime, order: 'ASC' }],
      options: { top: 1000 }
    })
  }).then(function(resp) {
    if (!resp.ok) throw new Error('API error: ' + resp.status);
    return resp.json();
  }).then(function(json) { return json.data || []; });
}

function apiQueryTable(tableId, where, select, top) {
  return fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST',
    headers: {
      'QB-Realm-Hostname': QB.realm,
      'Authorization': 'QB-USER-TOKEN ' + QB.token,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      from: tableId,
      where: where,
      select: select,
      options: { top: top || 1000 }
    })
  }).then(function(resp) {
    if (!resp.ok) throw new Error('API error: ' + resp.status);
    return resp.json();
  }).then(function(json) { return json.data || []; });
}

/* ===== LATE STATUS DATA ===== */
var lateByTask = {}; // taskRid → {type, timestamp, scheduled, crew}
var lateDataLoaded = false;

function loadLateData() {
  // Build set of task RIDs and their project RIDs from current data
  var projRids = {};
  var taskRidSet = {};
  allTasks.forEach(function(t) {
    var taskRid = String(qbv(t, 3) || '');
    var projRid = String(qbv(t, F.relatedProject) || '');
    if (taskRid) taskRidSet[taskRid] = true;
    if (projRid) projRids[projRid] = true;
  });
  var projList = Object.keys(projRids);
  if (!projList.length) return Promise.resolve();

  // Query task log by project RIDs
  var promises = projList.map(function(projRid) {
    var where = "{'" + LOG_F.relatedProject + "'.EX.'" + projRid + "'}";
    return apiQueryTable(QB.arrivyTaskLogTable, where, LOG_SELECT, 300).catch(function() { return []; });
  });

  return Promise.all(promises).then(function(results) {
    var priority = { 'NO_SHOW': 3, 'NOSHOW': 3, 'LATE': 2, 'PREDICTED_LATE': 1 };
    lateByTask = {};
    results.forEach(function(logs) {
      logs.forEach(function(log) {
        var et = (qbv(log, LOG_F.eventType) || '').toUpperCase();
        var p = priority[et];
        if (!p) return;
        var taskRid = String(qbv(log, LOG_F.relatedTask) || '');
        if (!taskRid || !taskRidSet[taskRid]) return;
        var existing = lateByTask[taskRid];
        if (existing && (priority[existing.type] || 0) >= p) return;
        var type = et === 'NO_SHOW' ? 'NOSHOW' : et;
        lateByTask[taskRid] = {
          type: type,
          timestamp: qbv(log, LOG_F.timestamp) || '',
          scheduled: qbv(log, LOG_F.scheduled) || '',
          crew: qbv(log, LOG_F.reporterName) || ''
        };
      });
    });
    lateDataLoaded = true;
  });
}

function getLateDelta(scheduled, timestamp) {
  if (!scheduled || !timestamp) return '';
  var s = new Date(scheduled);
  var t = new Date(timestamp);
  if (isNaN(s) || isNaN(t)) return '';
  var diffMin = Math.round((t - s) / 60000);
  if (diffMin <= 0) return '';
  if (diffMin < 60) return '+' + diffMin + 'm';
  var h = Math.floor(diffMin / 60);
  var m = diffMin % 60;
  return '+' + h + 'h' + (m > 0 ? m + 'm' : '');
}

/* ===== LOAD DATA ===== */
function loadData() {
  showLoading(true);
  var range = getDateRange(activePreset);
  var fromStr = formatDate(range.from) + 'T00:00:00Z';
  var toStr = formatDate(range.to) + 'T23:59:59Z';
  var where = "{'" + F.scheduledDateTime + "'.OAF.'" + fromStr + "'}AND{'" + F.scheduledDateTime + "'.OBF.'" + toStr + "'}";

  // Update header date
  var opts = { month: 'short', day: 'numeric', year: 'numeric' };
  document.getElementById('headerDate').textContent = activePreset === 'today' ? 'Today' : range.from.toLocaleDateString('en-US', opts);

  apiQuery(where)
  .then(function(data) {
    allTasks = data;
    lateByTask = {};
    lateDataLoaded = false;
    renderKPIs();
    renderLeaderboard();
    renderEventBreakdown();
    renderActivityFeed();
    updateHeaderSubtitle();
    showLoading(false);
    // Non-blocking: load late data then re-render with late metrics
    loadLateData().then(function() {
      renderKPIs();
      renderLeaderboard();
      renderEventBreakdown();
    }).catch(function(e) { console.warn('Late data load failed:', e); });
  })
  .catch(function(e) {
    console.error('Load error:', e);
    showError('Failed to load field data: ' + e.message);
    showLoading(false);
  });
}

/* ===== KPI RENDERING ===== */
function isSurveyOverdue(t) {
  // Survey-type task, scheduled + 2 hours has passed, and not yet submitted
  var tmpl = (qbv(t, F.templateName) || '').toLowerCase();
  if (tmpl.indexOf('survey') < 0) return false;
  if (qbv(t, F.submittedDateTime)) return false;
  var sched = qbv(t, F.scheduledDateTime);
  if (!sched) return false;
  var schedDate = new Date(sched);
  var cutoff = new Date(schedDate.getTime() + (2 * 60 * 60 * 1000)); // +2 hours
  return new Date() > cutoff;
}

function renderKPIs() {
  var tasks = getFilteredTasks();
  var total = tasks.length;
  var submittedCount = 0;
  var notSubmittedCount = 0;
  var ssOverdueCount = 0;
  var activeNow = 0;

  tasks.forEach(function(t) {
    var s = getTaskStatus(t);
    if (s.key === 'submitted') submittedCount++;
    else if (s.key === 'notsubmitted') notSubmittedCount++;
    else if (s.key === 'onsite' || s.key === 'enroute') activeNow++;
    // SS Overdue: survey-specific, scheduled + 2hrs passed
    if (isSurveyOverdue(t)) ssOverdueCount++;
  });

  // Count late tasks (surveys only)
  var lateCount = 0;
  if (lateDataLoaded) {
    tasks.forEach(function(t) {
      var rid = String(qbv(t, 3) || '');
      var tmpl = (qbv(t, F.templateName) || '').toLowerCase();
      if (lateByTask[rid] && tmpl.indexOf('survey') >= 0) lateCount++;
    });
  }

  document.getElementById('kpiStrip').innerHTML =
    '<div class="kpi-chip accent-info tappable" onclick="drillDownKPI(\'all\')">' +
      '<div class="kpi-label">Total</div><div class="kpi-value">' + total + '</div></div>' +
    '<div class="kpi-chip accent-danger tappable" onclick="drillDownKPI(\'notsubmitted\')">' +
      '<div class="kpi-label">Not Submitted</div><div class="kpi-value">' + notSubmittedCount + '</div></div>' +
    (lateDataLoaded ? '<div class="kpi-chip accent-warning tappable" onclick="drillDownKPI(\'late\')">' +
      '<div class="kpi-label">SS Late</div><div class="kpi-value">' + lateCount + '</div></div>' : '') +
    '<div class="kpi-chip accent-danger tappable" onclick="drillDownKPI(\'ssoverdue\')">' +
      '<div class="kpi-label">SS Overdue</div><div class="kpi-value">' + ssOverdueCount + '</div></div>' +
    '<div class="kpi-chip accent-success tappable" onclick="drillDownKPI(\'submitted\')">' +
      '<div class="kpi-label">Submitted</div><div class="kpi-value">' + submittedCount + '</div></div>' +
    '<div class="kpi-chip accent-teal tappable" onclick="drillDownKPI(\'active\')">' +
      '<div class="kpi-label">On Site Now</div><div class="kpi-value">' + activeNow + '</div></div>';
}

/* ===== KPI DRILL-DOWN ===== */
function drillDownKPI(kpiKey) {
  var tasks = getFilteredTasks();
  var filtered;
  var title;

  if (kpiKey === 'all') {
    filtered = tasks;
    title = 'All Events';
  } else if (kpiKey === 'notsubmitted') {
    filtered = tasks.filter(function(t) { return getTaskStatus(t).key === 'notsubmitted'; });
    title = 'Not Submitted';
  } else if (kpiKey === 'ssoverdue') {
    filtered = tasks.filter(function(t) { return isSurveyOverdue(t); });
    title = 'SS Overdue';
  } else if (kpiKey === 'submitted') {
    filtered = tasks.filter(function(t) { return getTaskStatus(t).key === 'submitted'; });
    title = 'Submitted';
  } else if (kpiKey === 'late') {
    filtered = tasks.filter(function(t) {
      var tmpl = (qbv(t, F.templateName) || '').toLowerCase();
      return tmpl.indexOf('survey') >= 0 && lateByTask[String(qbv(t, 3) || '')];
    });
    title = 'Late Surveys';
  } else if (kpiKey === 'active') {
    filtered = tasks.filter(function(t) {
      var k = getTaskStatus(t).key;
      return k === 'onsite' || k === 'enroute';
    });
    title = 'On Site Now';
  } else {
    filtered = tasks;
    title = 'Events';
  }

  showDrillDown(title, filtered);
}

/* ===== SEARCH FILTER ===== */
function getFilteredTasks() {
  if (!searchTerm) return allTasks;
  var q = searchTerm.toLowerCase();
  return allTasks.filter(function(t) {
    var tech = (getCrewName(t) || '').toLowerCase();
    var tmpl = (qbv(t, F.templateName) || '').toLowerCase();
    var fn = (qbv(t, F.customerFirstName) || '').toLowerCase();
    var ln = (qbv(t, F.customerLastName) || '').toLowerCase();
    return tech.indexOf(q) >= 0 || tmpl.indexOf(q) >= 0 || fn.indexOf(q) >= 0 || ln.indexOf(q) >= 0;
  });
}

/* ===== LEADERBOARD ===== */
var techList = []; // store tech names for safe onclick lookup
function renderLeaderboard() {
  var tasks = getFilteredTasks();
  var techMap = {};

  tasks.forEach(function(t) {
    var name = getCrewName(t) || 'Unassigned';
    if (!techMap[name]) techMap[name] = { total: 0, completed: 0 };
    techMap[name].total++;
    if (qbv(t, F.submittedDateTime)) techMap[name].completed++;
  });

  techList = Object.keys(techMap).sort(function(a,b) { return techMap[b].total - techMap[a].total; });
  var container = document.getElementById('techCards');

  if (!techList.length) {
    container.innerHTML = '<div class="empty-state">No tasks in selected date range</div>';
    return;
  }

  var html = '';
  techList.forEach(function(name, idx) {
    var d = techMap[name];
    var rate = d.total > 0 ? Math.round((d.completed / d.total) * 100) : 0;
    var barCls = rate >= 80 ? 'green' : (rate >= 50 ? 'yellow' : 'red');
    html += '<div class="tech-card" onclick="drillDownTech(techList[' + idx + '])">' +
      '<div class="tech-avatar">' + escapeHtml(getInitials(name)) + '</div>' +
      '<div class="tech-info">' +
        '<div class="tech-name">' + escapeHtml(name) + '</div>' +
        '<div class="tech-stats">' + d.total + ' events · ' + d.completed + ' completed · ' + rate + '% rate</div>' +
        '<div class="tech-bar"><div class="tech-bar-fill ' + barCls + '" style="width:' + rate + '%"></div></div>' +
      '</div>' +
      '<div class="tech-count">' + d.total + '</div>' +
    '</div>';
  });
  container.innerHTML = html;
}

/* ===== EVENT BREAKDOWN ===== */
var eventTypeList = []; // store event types for safe onclick lookup
function renderEventBreakdown() {
  var tasks = getFilteredTasks();

  // Build per-type status counts
  var typeMap = {};
  tasks.forEach(function(t) {
    var tmpl = qbv(t, F.templateName) || 'Other';
    if (!typeMap[tmpl]) typeMap[tmpl] = { total: 0, submitted: 0, notsubmitted: 0, onsite: 0, scheduled: 0, late: 0 };
    typeMap[tmpl].total++;
    var s = getTaskStatus(t);
    if (s.key === 'submitted') typeMap[tmpl].submitted++;
    else if (s.key === 'notsubmitted') typeMap[tmpl].notsubmitted++;
    else if (s.key === 'onsite' || s.key === 'enroute') typeMap[tmpl].onsite++;
    else typeMap[tmpl].scheduled++;
    if (lateDataLoaded && tmpl.toLowerCase().indexOf('survey') >= 0 && lateByTask[String(qbv(t, 3) || '')]) typeMap[tmpl].late++;
  });

  eventTypeList = Object.keys(typeMap).sort(function(a,b) { return typeMap[b].total - typeMap[a].total; });
  var container = document.getElementById('eventBreakdown');

  if (!eventTypeList.length) {
    container.innerHTML = '<div class="empty-state">No data</div>';
    return;
  }

  var html = '<div class="breakdown-card">';
  eventTypeList.forEach(function(type, idx) {
    var d = typeMap[type];
    var tot = d.total;
    var subPct = tot > 0 ? (d.submitted / tot) * 100 : 0;
    var nsPct = tot > 0 ? (d.notsubmitted / tot) * 100 : 0;
    var osPct = tot > 0 ? (d.onsite / tot) * 100 : 0;
    var schPct = tot > 0 ? (d.scheduled / tot) * 100 : 0;
    var rate = tot > 0 ? Math.round((d.submitted / tot) * 100) : 0;
    var onTimePct = tot > 0 ? Math.round(((tot - d.late) / tot) * 100) : 100;
    var lateText = '';
    if (lateDataLoaded && d.late > 0) {
      var lateColor = onTimePct >= 90 ? 'var(--success)' : onTimePct >= 70 ? 'var(--warning)' : 'var(--danger)';
      lateText = '<span style="font-size:10px;color:' + lateColor + ';font-weight:600;margin-left:6px">' + onTimePct + '% on-time</span>';
    }

    html += '<div class="breakdown-item" onclick="drillDownEventType(eventTypeList[' + idx + '])">' +
      '<div class="breakdown-top">' +
        '<div class="breakdown-label">' + escapeHtml(type) + lateText + '</div>' +
        '<div class="breakdown-count">' + tot + '<span class="rate">' + rate + '%</span></div>' +
      '</div>' +
      '<div class="breakdown-bar">' +
        (subPct > 0 ? '<div class="breakdown-seg seg-submitted" style="width:' + subPct + '%"></div>' : '') +
        (nsPct > 0 ? '<div class="breakdown-seg seg-notsubmitted" style="width:' + nsPct + '%"></div>' : '') +
        (osPct > 0 ? '<div class="breakdown-seg seg-onsite" style="width:' + osPct + '%"></div>' : '') +
        (schPct > 0 ? '<div class="breakdown-seg seg-scheduled" style="width:' + schPct + '%"></div>' : '') +
      '</div>' +
    '</div>';
  });

  // Legend
  html += '<div class="breakdown-legend">' +
    '<div class="legend-item"><div class="legend-dot" style="background:var(--success)"></div>Submitted</div>' +
    '<div class="legend-item"><div class="legend-dot" style="background:var(--danger)"></div>Not Submitted</div>' +
    '<div class="legend-item"><div class="legend-dot" style="background:var(--info)"></div>On Site</div>' +
    '<div class="legend-item"><div class="legend-dot" style="background:var(--warm)"></div>Scheduled</div>' +
  '</div>';

  html += '</div>';
  container.innerHTML = html;
}

/* ===== ACTIVITY FEED ===== */
function renderActivityFeed() {
  var tasks = getFilteredTasks();
  var container = document.getElementById('activityContainer');

  if (!tasks.length) {
    container.innerHTML = '<div class="empty-state">No activities for this date range</div>';
    return;
  }

  var grouped = { morning: [], afternoon: [], evening: [] };
  tasks.forEach(function(t) {
    var sched = qbv(t, F.scheduledDateTime);
    if (sched) {
      var hour = new Date(sched).getHours();
      if (hour < 12) grouped.morning.push(t);
      else if (hour < 17) grouped.afternoon.push(t);
      else grouped.evening.push(t);
    }
  });

  var html = '';
  var periods = [
    { key: 'morning', label: 'Morning' },
    { key: 'afternoon', label: 'Afternoon' },
    { key: 'evening', label: 'Evening' }
  ];

  periods.forEach(function(p) {
    if (!grouped[p.key].length) return;
    html += '<div class="time-section-header">' + p.label + '</div>';

    grouped[p.key].forEach(function(t) {
      var sched = qbv(t, F.scheduledDateTime);
      var fn = qbv(t, F.customerFirstName) || '';
      var ln = qbv(t, F.customerLastName) || '';
      var tmpl = qbv(t, F.templateName) || 'Task';
      var tech = getCrewName(t) || 'Unassigned';

      var status = 'not-started'; var statusLabel = 'Not Started';
      if (qbv(t, F.submittedDateTime)) { status = 'submitted'; statusLabel = 'Submitted'; }
      else if (qbv(t, F.startedStatus)) { status = 'arrived'; statusLabel = 'Arrived'; }
      else if (qbv(t, F.enrouteStatus)) { status = 'enroute'; statusLabel = 'En Route'; }

      html += '<div class="activity-card">' +
        '<div class="activity-dot ' + status + '"></div>' +
        '<div class="activity-body">' +
          '<div class="activity-primary">' + escapeHtml(tech) + ' &mdash; ' + escapeHtml(fn + ' ' + ln).trim() + '</div>' +
          '<div class="activity-meta">' + formatTime(sched) + ' · ' + escapeHtml(tmpl) +
            '<span class="activity-status ' + status + '">' + statusLabel + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    });
  });

  container.innerHTML = html;
}

