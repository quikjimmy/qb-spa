  if (!tasks.length) {
    container.innerHTML = '<div class="empty-state">No tasks found</div>';
    document.getElementById('scrollArea').scrollTop = 0;
    return;
  }

  // Group by status
  var groups = { notsubmitted: [], overdue: [], onsite: [], enroute: [], scheduled: [], submitted: [] };
  tasks.forEach(function(t) {
    var status = getTaskStatus(t);
    if (groups[status.key]) groups[status.key].push(t);
    else groups.scheduled.push(t);
  });

  var html = '';
  var cfg = [
    { key: 'notsubmitted', label: 'Not Submitted', color: 'color:var(--danger)' },
    { key: 'overdue', label: 'Overdue', color: 'color:var(--danger)' },
    { key: 'onsite', label: 'On Site', color: 'color:var(--info)' },
    { key: 'enroute', label: 'En Route', color: 'color:var(--info)' },
    { key: 'scheduled', label: 'Scheduled', color: '' },
    { key: 'submitted', label: 'Submitted', color: 'color:var(--success)' }
  ];

  cfg.forEach(function(g) {
    if (!groups[g.key] || !groups[g.key].length) return;
    var groupId = 'drillgroup_' + g.key;
    html += '<div class="group-header" style="' + g.color + '" onclick="toggleGroupCards(\'' + groupId + '\')">' +
      '<span class="collapse-arrow" id="arrow_' + groupId + '">&#9660;</span> ' + g.label +
      ' <span class="group-count">' + groups[g.key].length + '</span></div>';
    html += '<div class="group-cards" id="' + groupId + '">';
    groups[g.key].forEach(function(t) { html += renderTaskCard(t); });
    html += '</div>';
  });

  container.innerHTML = html;
  document.getElementById('scrollArea').scrollTop = 0;
}

