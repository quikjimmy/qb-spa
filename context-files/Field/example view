function getTaskStatus(t) {
  var arrivyStatus = (qbv(t, F.taskStatus) || '').toLowerCase();
  var submittedDt = qbv(t, F.submittedDateTime);
  var arrivedDt = qbv(t, F.startedStatus);
  var enrouteDt = qbv(t, F.enrouteStatus);
  var isArrivyComplete = arrivyStatus === 'complete' || arrivyStatus === 'site work complete';
  var isOverdue = arrivyStatus === 'overdue';

  // Truth-based status: what ACTUALLY happened, not what Arrivy's label says

  // 1. Arrivy says complete/SWC but tech never submitted their form = Not Submitted (red flag)
  if (isArrivyComplete && !submittedDt) return { key: 'notsubmitted', label: 'Not Submitted', cls: 'overdue', border: 'border-red' };

  // 2. Tech submitted their form = Submitted (the real completion signal)
  if (submittedDt) return { key: 'submitted', label: 'Submitted', cls: 'complete', border: 'border-green' };

  // 3. Overdue = past scheduled time, nothing done
  if (isOverdue) return { key: 'overdue', label: 'Overdue', cls: 'overdue', border: 'border-red' };

  // 4. Tech arrived on site but hasn't submitted yet
  if (arrivedDt) return { key: 'onsite', label: 'On Site', cls: 'onsite', border: 'border-blue' };

  // 5. Tech en route
  if (enrouteDt) return { key: 'enroute', label: 'En Route', cls: 'enroute', border: 'border-blue' };

  // 6. Nothing happened yet
  return { key: 'scheduled', label: 'Scheduled', cls: 'scheduled', border: '' };
}

function getStatusEmoji(t) {
  var s = getTaskStatus(t);
  if (s.key === 'submitted') return '\u2705';
  if (s.key === 'notsubmitted') return '\u274C';
  if (s.key === 'onsite') return '\uD83D\uDEA7';
  if (s.key === 'enroute') return '\uD83D\uDE97';
  if (s.key === 'overdue') return '\u26A0\uFE0F';
  return '\u23F3';
}

function renderTaskCard(t) {
  var fn = qbv(t, F.customerFirstName) || '';
  var ln = qbv(t, F.customerLastName) || '';
  var name = (fn + ' ' + ln).trim() || 'Unknown';
  var tmpl = qbv(t, F.templateName) || 'Task';
  var crew = getCrewName(t) || 'TBA';
  var sched = qbv(t, F.scheduledDateTime);
  var taskUrl = qbv(t, F.taskUrl);
  var kw = parseFloat(qbv(t, F.kw) || 0);
  var projRid = qbv(t, F.relatedProject);
  var taskRid = qbv(t, 3);
  var status = getTaskStatus(t);
  var emoji = getStatusEmoji(t);
  var installComp = (qbv(t, F.installComplete) || '').toLowerCase() === 'yes';
  var submittedDt = qbv(t, F.submittedDateTime);
  var rtrStatus = (qbv(t, F.rtrStatus) || '').toLowerCase();
  var rtrCount = parseInt(qbv(t, F.rtrReadyCount) || 0);

  var erOn = qbv(t, F.enrouteStatus) ? 'on' : 'off';
  var osOn = qbv(t, F.startedStatus) ? 'on' : 'off';
  var subCls = submittedDt ? 'on' : ((installComp && !submittedDt) ? 'missed' : 'off');
  var compCls = installComp ? 'on' : 'off';

  // Determine event category from template name
  var tmplLow = tmpl.toLowerCase();
  var eventCategory = 'install'; // default
  if (tmplLow.indexOf('survey') >= 0 || tmplLow.indexOf('document') >= 0) eventCategory = 'survey';
  else if (tmplLow.indexOf('inspection') >= 0 || tmplLow.indexOf('inspect') >= 0) eventCategory = 'inspection';
  else if (tmplLow.indexOf('service') >= 0) eventCategory = 'service';

  // Build chip row based on event category
  var chipsHtml = '';
  var arrivyStatus = (qbv(t, F.taskStatus) || '').toLowerCase();
  var isTaskComplete = arrivyStatus === 'complete' || arrivyStatus === 'site work complete';

  if (eventCategory === 'install' || eventCategory === 'default') {
    // Install / Electrical Upgrade: ER | OS | SUB | COMP | RTR
    var rtrChip = '';
    if (rtrStatus.indexOf('pass') >= 0) rtrChip = '<span class="fs-chip on">\u2705 RTR</span>';
    else if (rtrStatus.indexOf('fail') >= 0) rtrChip = '<span class="fs-chip missed">\u274C RTR</span>';
    else if (rtrStatus || rtrCount > 0) rtrChip = '<span class="fs-chip off">\u26A0\uFE0F RTR</span>';
    else if (installComp) rtrChip = '<span class="fs-chip" style="background:#f97316;color:#fff">!RTR</span>';
    else rtrChip = '<span class="fs-chip off">RTR</span>';

    chipsHtml =
      '<span class="fs-chip ' + erOn + '">\uD83D\uDE97 ER</span>' +
      '<span class="fs-chip ' + osOn + '">\uD83D\uDEA7 OS</span>' +
      '<span class="fs-chip ' + subCls + '">' + (submittedDt ? '\u2705' : '\u274C') + ' SUB</span>' +
      '<span class="fs-chip ' + compCls + '">' + (installComp ? '\u2705' : '') + ' COMP</span>' +
      rtrChip;

  } else if (eventCategory === 'survey') {
    // Survey / Document: ER | OS | SUB | APPR
    // Without project data we use: submitted = form done, complete status = approved proxy
    var apprCls = isTaskComplete ? 'on' : (submittedDt && !isTaskComplete ? 'off' : 'off');
    var apprIcon = isTaskComplete ? '\u2705' : '';
    chipsHtml =
      '<span class="fs-chip ' + erOn + '">\uD83D\uDE97 ER</span>' +
      '<span class="fs-chip ' + osOn + '">\uD83D\uDEA7 OS</span>' +
      '<span class="fs-chip ' + subCls + '">' + (submittedDt ? '\u2705' : '\u274C') + ' SUB</span>' +
      '<span class="fs-chip ' + apprCls + '">' + apprIcon + ' APPR</span>';

  } else if (eventCategory === 'inspection') {
    // Inspection: ER | OS | SUB | PASS
    var isFailed = arrivyStatus.indexOf('fail') >= 0;
    var passCls = isTaskComplete && !isFailed ? 'on' : (isFailed ? 'missed' : 'off');
    var passIcon = isTaskComplete && !isFailed ? '\u2705' : (isFailed ? '\u274C' : '');
    chipsHtml =
      '<span class="fs-chip ' + erOn + '">\uD83D\uDE97 ER</span>' +
      '<span class="fs-chip ' + osOn + '">\uD83D\uDEA7 OS</span>' +
      '<span class="fs-chip ' + subCls + '">' + (submittedDt ? '\u2705' : (isTaskComplete ? '\u274C' : '')) + ' SUB</span>' +
      '<span class="fs-chip ' + passCls + '">' + passIcon + ' PASS</span>';

  } else if (eventCategory === 'service') {
    // Service: ER | OS | SUB | RESOLVED
    var resolvedCls = isTaskComplete ? 'on' : 'off';
    var resolvedIcon = isTaskComplete ? '\u2705' : '';
    chipsHtml =
      '<span class="fs-chip ' + erOn + '">\uD83D\uDE97 ER</span>' +
      '<span class="fs-chip ' + osOn + '">\uD83D\uDEA7 OS</span>' +
      '<span class="fs-chip ' + subCls + '">' + (submittedDt ? '\u2705' : '\u274C') + ' SUB</span>' +
      '<span class="fs-chip ' + resolvedCls + '">' + resolvedIcon + ' DONE</span>';
  }

  // Sub-line: time · template · kW · crew
  var subParts = [fmtDateTime(sched), escapeHtml(tmpl)];
  if (kw > 0) subParts.push(kw.toFixed(1) + ' kW');
  subParts.push(escapeHtml(crew));

  // Project detail link
  var projectUrl = projRid ? 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=qb-skin-project-detail.html#rid=' + encodeURIComponent(projRid) : '';
  var cardClick = projectUrl ? ' onclick="if(!event.target.closest(\'.arrivy-link,.arrivy-drawer-toggle,.arrivy-drawer-content\')){window.location.href=\'' + projectUrl + '\';}"' : '';

  // Arrivy drawer (lazy-load all tasks for this project)
  var drawerHtml = '';
  if (projRid) {
    var drawerId = 'adrawer_' + String(projRid) + '_' + String(taskRid || '');
    drawerHtml = '<div class="arrivy-drawer-slot" data-project-rid="' + escapeHtml(String(projRid)) + '" data-current-rid="' + escapeHtml(String(taskRid || '')) + '" data-loaded="0">' +
      '<div class="arrivy-drawer-toggle" onclick="event.stopPropagation();toggleArrivyDrawer(this.parentElement)">' +
        '<span class="arrivy-drawer-label">Field Activity</span><span class="arrivy-drawer-arrow">&#9654;</span>' +
      '</div>' +
      '<div id="' + drawerId + '" class="arrivy-drawer-content" style="display:none"></div>' +
    '</div>';
  }

  // Late badge
  var lateBadgeHtml = '';
  if (lateDataLoaded && taskRid && lateByTask[String(taskRid)] && tmplLow.indexOf('survey') >= 0) {
    var li = lateByTask[String(taskRid)];
    var curSt = (qbv(t, F.taskStatus) || '').toLowerCase().replace(/\s+/g, '');
    var isStillLate = curSt === 'late' || curSt === 'predictedlate' || curSt === 'predicted_late' || curSt === 'noshow';
    if (isStillLate) {
      var lBadgeCls = li.type === 'NOSHOW' ? 'noshow' : (li.type === 'LATE' ? 'late' : 'predicted');
      var lLabel = li.type === 'NOSHOW' ? 'NO SHOW' : (li.type === 'LATE' ? 'LATE' : 'PRED. LATE');
      var lDelta = getLateDelta(li.scheduled, li.timestamp);
      lateBadgeHtml = '<span class="late-badge ' + lBadgeCls + '">' + lLabel + (lDelta ? ' ' + lDelta : '') + '</span>';
    } else {
      lateBadgeHtml = '<span class="late-badge was-late">was late</span>';
    }
  }

  return '<div class="task-card ' + status.border + '" style="cursor:pointer"' + cardClick + '>' +
    '<div class="card-header">' +
      '<div class="card-title">' + emoji + ' ' + escapeHtml(name) + '</div>' +
      '<span class="status-pill ' + status.cls + '">' + escapeHtml(status.label) + '</span>' + lateBadgeHtml +
    '</div>' +
    '<div class="card-sub">' + subParts.join(' &middot; ') + '</div>' +
    '<div class="fs-row">' + chipsHtml + '</div>' +
    (taskUrl ? '<a class="arrivy-link" href="' + escapeHtml(taskUrl) + '" target="_blank" rel="noopener" onclick="event.stopPropagation()">Open in Arrivy &#8599;</a>' : '') +
    drawerHtml +
  '</div>';
}

