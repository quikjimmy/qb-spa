/* ===== ARRIVY DRAWER (lazy-load all tasks for a project) ===== */
var drawerCache = {};

function toggleArrivyDrawer(slot) {
  if (!slot) return;
  var projRid = String(slot.dataset.projectRid || '');
  var currentRid = slot.dataset.currentRid || '';
  var contentEl = slot.querySelector('.arrivy-drawer-content');
  var arrowEl = slot.querySelector('.arrivy-drawer-arrow');
  var labelEl = slot.querySelector('.arrivy-drawer-label');
  if (!contentEl) return;

  // Already loaded — just toggle
  if (slot.dataset.loaded === '1') {
    var isOpen = contentEl.style.display !== 'none';
    contentEl.style.display = isOpen ? 'none' : 'block';
    if (arrowEl) arrowEl.classList.toggle('open', !isOpen);
    return;
  }

  // First click — fetch all Arrivy tasks for this project
  if (labelEl) labelEl.textContent = 'Loading...';

  if (drawerCache[projRid]) {
    renderDrawerRows(drawerCache[projRid], projRid, currentRid, contentEl, labelEl, arrowEl, slot);
    return;
  }

  var where = "{'" + F.relatedProject + "'.EX.'" + projRid + "'}";
  fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST',
    headers: {
      'QB-Realm-Hostname': QB.realm,
      'Authorization': 'QB-USER-TOKEN ' + QB.token,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      from: QB.arrivyTable,
      where: where,
      select: SELECT_FIELDS,
      sortBy: [{ fieldId: F.scheduledDateTime, order: 'ASC' }],
      options: { top: 200 }
    })
  })
  .then(function(resp) { return resp.json(); })
  .then(function(json) {
    var tasks = json.data || [];
    drawerCache[projRid] = tasks;
    renderDrawerRows(tasks, projRid, currentRid, contentEl, labelEl, arrowEl, slot);
  })
  .catch(function(e) {
    console.error('Drawer load error:', e);
    if (labelEl) labelEl.textContent = 'Field Activity (error)';
  });
}

function renderDrawerRows(tasks, projRid, currentRid, contentEl, labelEl, arrowEl, slot) {
  if (!tasks.length) {
    if (labelEl) labelEl.textContent = 'No field activity';
    slot.dataset.loaded = '1';
    return;
  }

  var rows = '';
  tasks.forEach(function(t) {
    var rid = qbv(t, 3);
    var tmpl = qbv(t, F.templateName) || 'Task';
    var dt = qbv(t, F.scheduledDateTime);
    var crew = getCrewName(t);
    var st = (qbv(t, F.taskStatus) || 'Scheduled').toLowerCase();
    var isCurrent = String(rid) === String(currentRid);

    var dotColor = '#94a3b8';
    if (st === 'complete' || st === 'site work complete') dotColor = '#10b981';
    else if (st === 'overdue') dotColor = '#ef4444';
    else if (qbv(t, F.submittedDateTime)) dotColor = '#f59e0b';
    else if (qbv(t, F.startedStatus)) dotColor = '#3b82f6';
    else if (qbv(t, F.enrouteStatus)) dotColor = '#3b82f6';

    var highlight = isCurrent ? ' style="background:#f0f9ff;border-radius:6px;padding:2px 4px;margin:-2px -4px"' : '';
    var fmtDt = dt ? new Date(dt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'TBD';

    var dRtr = (qbv(t, F.rtrStatus) || '').toLowerCase();
    var rtrDotColor = dRtr.indexOf('pass') >= 0 ? '#10b981' : dRtr.indexOf('fail') >= 0 ? '#ef4444' : dRtr ? '#f59e0b' : '#cbd5e1';
    var rtrDot = '<span style="width:6px;height:6px;border-radius:50%;background:' + rtrDotColor + ';display:inline-block;margin-left:2px"></span>';

    var tmplDisplay = tmpl.length > 22 ? tmpl.slice(0, 20) + '\u2026' : tmpl;
    rows += '<div class="arrivy-drawer-row"' + highlight + '>' +
      '<span class="arrivy-drawer-dot" style="background:' + dotColor + '"></span>' +
      '<span class="arrivy-drawer-tmpl">' + escapeHtml(tmplDisplay) + rtrDot + '</span>' +
      '<span class="arrivy-drawer-date">' + fmtDt + '</span>' +
      (crew ? '<span class="arrivy-drawer-crew">' + escapeHtml(crew.split(' ')[0]) + '</span>' : '') +
    '</div>';
  });

  contentEl.innerHTML = rows;
  contentEl.style.display = 'block';
  if (labelEl) labelEl.textContent = 'Field Activity (' + tasks.length + ')';
  if (arrowEl) arrowEl.classList.add('open');
  slot.dataset.loaded = '1';
}

/* ===== LOADING/ERROR ===== */
function showLoading(show) {
  document.getElementById('loadingOverlay').classList.toggle('hidden', !show);
}
function showError(msg) {
  document.getElementById('errorText').textContent = msg;
  document.getElementById('errorBanner').classList.add('show');
}

/* ===== PERSONALIZED GREETING ===== */
var detectedUserName = '';
var defaultTitle = 'Field';

function getTimeGreeting() {
  var h = new Date().getHours();
  if (h < 12) return 'Good morning';
  if (h < 17) return 'Good afternoon';
  return 'Good evening';
}

function detectCurrentUser() {
  return fetch('https://' + QB.realm + '/db/main?a=API_GetUserInfo&fmt=structured', {
    method: 'GET', credentials: 'include'
  })
  .then(function(resp) {
    if (!resp.ok) throw new Error('Not in QB');
    return resp.text();
  })
  .then(function(xml) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(xml, 'text/xml');
    var errcode = doc.querySelector('errcode');
    if (errcode && errcode.textContent !== '0') throw new Error('Auth error');
    var firstName = doc.querySelector('firstName');
    if (firstName && firstName.textContent.trim()) {
      detectedUserName = firstName.textContent.trim();
      defaultTitle = getTimeGreeting() + ', ' + detectedUserName;
      document.getElementById('headerTitle').textContent = defaultTitle;
    }
  })
  .catch(function() {
    defaultTitle = getTimeGreeting();
    document.getElementById('headerTitle').textContent = defaultTitle;
  });
}

function updateHeaderSubtitle() {
  var tasks = allTasks;
  var notSub = 0; var overdue = 0;
  tasks.forEach(function(t) {
    var s = getTaskStatus(t);
    if (s.key === 'notsubmitted') notSub++;
    else if (s.key === 'overdue') overdue++;
  });

  var el = document.getElementById('headerDate');
  var opts = { month: 'short', day: 'numeric', year: 'numeric' };
  var range = getDateRange(activePreset);
  var dateText = activePreset === 'today' ? 'Today' : range.from.toLocaleDateString('en-US', opts);

  var alerts = [];
  if (notSub > 0) alerts.push(notSub + ' not submitted');
  if (overdue > 0) alerts.push(overdue + ' overdue');

  if (alerts.length > 0) {
    el.innerHTML = dateText + ' &middot; <span style="color:#ef4444;font-weight:600">' + alerts.join(', ') + '</span>';
  } else {
    el.textContent = dateText;
  }
}

/* ===== INIT ===== */
function loadOverdueTicketBadge() {
  var today = new Date();
  var todayStr = today.getFullYear()+'-'+String(today.getMonth()+1).padStart(2,'0')+'-'+String(today.getDate()).padStart(2,'0');
  fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST',
    headers: { 'QB-Realm-Hostname': QB.realm, 'Authorization': 'QB-USER-TOKEN ' + QB.token, 'Content-Type': 'application/json' },
    body: JSON.stringify({
      from: 'bstdqwrkg',
      select: [3],
      where: "{'91'.XEX.'Completed'}AND{'91'.XEX.'Closed'}AND{'91'.XEX.'Complete'}AND{'166'.XEX.'true'}AND{'95'.OBF.'" + todayStr + "'}",
      options: { top: 500 }
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(json) {
    var count = (json.data || []).length;
    var badge = document.getElementById('ticketBadge');
    if (badge && count > 0) { badge.textContent = count; badge.style.display = 'inline-flex'; }
  })
  .catch(function() {});
}

document.addEventListener('DOMContentLoaded', function() {
  detectCurrentUser().then(function() {
    renderDateFilters();
    loadData();
  });
  loadOverdueTicketBadge();
});
</script>
