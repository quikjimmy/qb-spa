    slot.innerHTML=`<div class="arrivy-drawer-toggle" onclick="event.stopPropagation();var d=document.getElementById('${drawerId}');d.style.display=d.style.display==='none'?'block':'none';this.querySelector('.arrivy-drawer-arrow').classList.toggle('open')"><span class="arrivy-drawer-label">Arrivy Tasks (${tasks.length})</span><span class="arrivy-drawer-arrow">&#9654;</span></div><div id="${drawerId}" class="arrivy-drawer-content" style="display:none">${rows}</div>`;
