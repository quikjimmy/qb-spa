<script>
const QBSKIN_NAV = {
  dashboard: 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=cc-quick-glance.html',
  projectDetail: 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=qb-skin-project-detail.html',
  tasks: 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=qb-skin-tasks.html',
  labor: 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=qb-skin-labor.html',
  trends: 'https://kin.quickbase.com/db/br9kwm8bk?a=dbpage&pagename=qb-skin-trends.html'
};

/* ===== VIEW NAVIGATION ===== */
let activeKPI = 'sales';
let activeQuickFilter = 'all';

// ===== SESSION PERSISTENCE =====
const SESSION_KEY = 'qbskin_home_filters';
function saveFilterState() {
  try {
    const state = {
      dateFrom: document.getElementById('filterDateFrom').value,
      dateTo: document.getElementById('filterDateTo').value,
      datePreset: document.querySelector('.date-shortcut.active')?.textContent?.trim()||'',
      office: document.getElementById('filterOffice').value,
      state: document.getElementById('filterState').value,
      status: document.getElementById('filterStatus').value,
      closer: document.getElementById('filterCloser').value,
      setter: document.getElementById('filterSetter').value,
      kpi: activeKPI,
      quickFilter: activeQuickFilter
    };
    sessionStorage.setItem(SESSION_KEY, JSON.stringify(state));
  } catch(e) {}
}
function restoreFilterState() {
  try {
    const raw = sessionStorage.getItem(SESSION_KEY);
    if (!raw) return false;
    const s = JSON.parse(raw);
    // Restore date range
    if (s.dateFrom) document.getElementById('filterDateFrom').value = s.dateFrom;
    if (s.dateTo) document.getElementById('filterDateTo').value = s.dateTo;
    // Highlight correct date preset button
    if (s.datePreset) {
      document.querySelectorAll('.date-shortcut').forEach(b => {
        b.classList.toggle('active', b.textContent.trim() === s.datePreset);
      });
    }
    // Restore dropdown filters (populated later, so set value — populateSelect preserves it)
    if (s.office) document.getElementById('filterOffice').value = s.office;
    if (s.state) document.getElementById('filterState').value = s.state;
    if (s.status) document.getElementById('filterStatus').value = s.status;
    if (s.closer) document.getElementById('filterCloser').value = s.closer;
    if (s.setter) document.getElementById('filterSetter').value = s.setter;
    // Restore KPI tab
    if (s.kpi) { activeKPI = s.kpi; }
    if (s.quickFilter) { activeQuickFilter = s.quickFilter; }
    return true;
  } catch(e) { return false; }
}

const QUICK_FILTER_CONFIG = {
  sales: [{label:'All',value:'all'},{label:'Active',value:'Active'},{label:'Finance Hold',value:'Finance Hold'},{label:'Pending Cancel',value:'Pending Cancel'}],
  kca: [{label:'All',value:'all'},{label:'Approved',value:'Approved'},{label:'Pending',value:'Pending'},{label:'Rejected',value:'Rejected'},{label:'Incomplete',value:'Incomplete'}],
  surveys: [{label:'All',value:'all'},{label:'Scheduled',value:'Scheduled'},{label:'En Route',value:'EnRoute'},{label:'On Site',value:'OnSite'},{label:'Submitted',value:'Submitted'},{label:'Overdue',value:'Overdue'}],
  installs: [{label:'All',value:'all'},{label:'Scheduled',value:'Scheduled'},{label:'En Route',value:'EnRoute'},{label:'On Site',value:'OnSite'},{label:'Submitted',value:'Submitted'},{label:'Complete',value:'Complete'},{label:'Overdue',value:'Overdue'}],
  inspections: [{label:'All',value:'all'},{label:'Scheduled',value:'Scheduled'},{label:'Submitted',value:'Submitted'},{label:'Overdue',value:'Overdue'}],
  favorites: [{label:'All',value:'all'},{label:'Active',value:'Active'},{label:'Finance Hold',value:'Finance Hold'},{label:'Pending Cancel',value:'Pending Cancel'}]
};

function selectKPI(kpi) {
  activeKPI = kpi;
  activeQuickFilter = 'all';
  document.querySelectorAll('.kpi-chip').forEach(c => c.classList.remove('selected'));
  var chip=document.querySelector(`.kpi-chip[data-kpi="${kpi}"]`);
  if(chip) chip.classList.add('selected');
  document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + kpi).classList.add('active');
  renderQuickFilters(kpi);
  saveFilterState();
  // Lazy-load favorites on first visit
  if(kpi==='favorites'&&!favoritesLoaded) loadFavorites();
}

function renderQuickFilters(kpi) {
  const container=document.getElementById('quickFilters');
  const filters=QUICK_FILTER_CONFIG[kpi]||[];
  if(!filters.length){container.classList.remove('visible');return;}
  container.classList.add('visible');
  container.innerHTML=filters.map(f=>`<button class="qf-chip${f.value===activeQuickFilter?' active':''}" onclick="applyQuickFilter('${f.value}')">${f.label}</button>`).join('');
}

function applyQuickFilter(val) {
  activeQuickFilter=val;
  saveFilterState();
  document.querySelectorAll('.qf-chip').forEach(c=>c.classList.remove('active'));
  event.target.classList.add('active');
  const panelId='panel-'+activeKPI;
  const panel=document.getElementById(panelId);
  if(!panel)return;
  panel.querySelectorAll('.record-card').forEach(card=>{
    if(val==='all'){card.style.display='';return;}
    // Sales/KCA filter by status or state
    const qf=(card.dataset.qf||'').toLowerCase();
    const st=(card.dataset.state||'').toLowerCase();
    const match=qf===val.toLowerCase()||st===val.toLowerCase();
    card.style.display=match?'':'none';
  });
}

// Build dynamic sales quick filters from actual data
function buildSalesQuickFilters(data,f) {
  const states=new Set(), statuses=new Set();
  data.forEach(r=>{const s=getVal(r,f.state);if(s)states.add(s);const st=getVal(r,f.status);if(st)statuses.add(st);});
  const filters=[{label:'All',value:'all'}];
  [...statuses].sort().forEach(s=>filters.push({label:s,value:s}));
  QUICK_FILTER_CONFIG.sales=filters;
  if(activeKPI==='sales') renderQuickFilters(activeKPI);
}

/* ===== SEARCH ===== */
let searchOpen = false;
function toggleSearch() {
  searchOpen = !searchOpen;
  const bar = document.getElementById('searchBar');
  const hdr = document.querySelector('.header');
  if (searchOpen) {
    bar.style.top = hdr.offsetHeight + 'px';
    bar.classList.add('open');
    document.getElementById('searchInput').focus();
  } else {
    bar.classList.remove('open');
    document.getElementById('searchInput').value = '';
    document.getElementById('globalResults').style.display = 'none';
    if (globalSearchMode) { globalSearchMode = false; document.getElementById('globalSearchBtn').classList.remove('active'); }
    handleSearch('');
  }
}

let globalSearchMode = false;
let globalSearchTimer = null;

function toggleGlobalSearch() {
  globalSearchMode = !globalSearchMode;
  const btn = document.getElementById('globalSearchBtn');
  const input = document.getElementById('searchInput');
  const globalResults = document.getElementById('globalResults');
  btn.classList.toggle('active', globalSearchMode);
  input.placeholder = globalSearchMode ? 'Search all projects...' : 'Search current view...';
  if (!globalSearchMode) {
    globalResults.style.display = 'none';
    handleSearch(input.value);
  } else {
    const q = input.value.trim();
    if (q.length >= 2) doGlobalSearch(q);
  }
}

function handleSearch(query) {
  const q = query.toLowerCase().trim();
  if (globalSearchMode) {
    clearTimeout(globalSearchTimer);
    if (q.length < 2) {
      document.getElementById('globalResults').style.display = 'none';
      return;
    }
    globalSearchTimer = setTimeout(() => doGlobalSearch(q), 400);
    return;
  }
  // Local search — filter visible cards
  document.getElementById('globalResults').style.display = 'none';
  document.querySelectorAll('.record-card').forEach(card => {
    if (!q) { card.style.display = ''; return; }
    card.style.display = card.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

async function doGlobalSearch(query) {
  const container = document.getElementById('globalResults');
  container.style.display = 'block';
  container.innerHTML = '<div class="searching-msg">Searching all projects...</div>';
  try {
    const q = query.replace(/'/g, "\\'");
    // Confirmed FIDs from Projects table (user-verified)
    const fullNameFid = 367; // Residential Client - Full Name
    const addressFid = 146;  // Customer Address
    const phoneFid = 148;    // Residential Client - Mobile Phone
    const emailFid = 149;    // Residential Client - Email
    const statusFid = 255;   // Status
    const kwFid = 13;        // System Size(kW)
    const stateFid = 189;    // Customer - State
    const sel = [3, fullNameFid, addressFid, phoneFid, emailFid, statusFid, kwFid, stateFid];

    // Infix OR syntax: {a}OR{b}OR{c} — QB requires this instead of OR({a}{b}{c}) for CT
    const where = `{${fullNameFid}.CT.'${q}'}OR{${addressFid}.CT.'${q}'}OR{${phoneFid}.CT.'${q}'}`;
    console.log('[QBSkin] Global search where:', where);
    const res = await apiQuery(CONFIG.tables.projects, where, sel, {top: 30});
    const data = res.data || [];

    if (!data.length) {
      container.innerHTML = '<div class="searching-msg">No projects found for "' + escapeHtml(query) + '"</div>';
      return;
    }
    container.innerHTML = data.map(r => {
      const rid = getVal(r, 3);
      const name = getVal(r, fullNameFid) || 'Unknown';
      const address = getVal(r, addressFid) || '';
      const phone = getVal(r, phoneFid) || '';
      const email = getVal(r, emailFid) || '';
      const status = getVal(r, statusFid) || '';
      const kw = parseFloat(getVal(r, kwFid) || 0);
      const state = getVal(r, stateFid) || '';
      const sub = [kw?kw.toFixed(1)+' kW':'', address, state].filter(Boolean).join(' \u00b7 ');
      const contact = [phone, email].filter(Boolean).join(' \u00b7 ');
