/* ===== PROGRESS TRACKER ===== */
function progressTracker(rec, f) {
  const now=new Date();
  // --- KCA: Green=Approved, Red=Rejected (project status), Yellow=Pending ---
  const intakeStatus=(getVal(rec,f.intakeStatus)||'').toLowerCase();
  const kcaStatusVal=(getVal(rec,f.kcaStatus)||'').toLowerCase();
  const projStatusLow=(getVal(rec,f.status)||'').toLowerCase();
  const intakeCompleted=getVal(rec,f.intakeCompleted);
  const hasIntake=intakeCompleted&&intakeCompleted!==''&&intakeCompleted!=='-';
  let kcaCls='not';
  if(hasIntake||intakeStatus==='complete'||intakeStatus==='approved'||kcaStatusVal==='approved') kcaCls='done';
  else if(projStatusLow.includes('reject')||intakeStatus.includes('reject')||kcaStatusVal.includes('reject')) kcaCls='rejected';
  else if(intakeStatus!==''||kcaStatusVal!=='') kcaCls='active';

  // --- Survey: Green=Approved, Red=Rejected, Yellow=Submitted not approved, Blue=Scheduled, Purple=Past date & not submitted ---
  const surveyApproved=getVal(rec,f.msSurvey); const hasSurveyApproved=surveyApproved&&surveyApproved!==''&&surveyApproved!=='-';
  const surveySubmitted=getVal(rec,f.surveySubmitted); const hasSurveySubmitted=surveySubmitted&&surveySubmitted!==''&&surveySubmitted!=='-';
  const surveySchedVal=getVal(rec,f.surveyScheduled); const hasSurveySched=surveySchedVal&&surveySchedVal!==''&&surveySchedVal!=='-';
  const surveyStatusVal=(getVal(rec,f.surveyStatus)||'').toLowerCase();
  let ssCls='not';
  if(hasSurveyApproved) ssCls='done';
  else if(surveyStatusVal.includes('reject')) ssCls='rejected';
  else if(hasSurveySubmitted) ssCls='active'; // yellow: submitted but not approved
  else if(hasSurveySched&&new Date(surveySchedVal+'T23:59:59')<now) ssCls='overdue'; // purple: past date, not submitted
  else if(hasSurveySched) ssCls='scheduled'; // blue: scheduled, not yet past

  // --- Design: Green=Complete, Yellow=CAD Submitted, Grey=Not started, + red notification badge if permit rejected (redesign only) ---
  const designCompleted=getVal(rec,f.msDesign); const hasDesign=designCompleted&&designCompleted!==''&&designCompleted!=='-';
  const cadSubmitted=getVal(rec,f.cadSubmitted); const hasCad=cadSubmitted&&cadSubmitted!==''&&cadSubmitted!=='-';
  const permitRejVal=getVal(rec,f.permitRejected); const hasPermitReject=permitRejVal&&permitRejVal!==''&&permitRejVal!=='-';
  let desCls='not';
  if(hasDesign) desCls='done';
  else if(hasCad) desCls='active'; // yellow: CAD submitted, design in progress
  // Red notification badge: only if permit was rejected (redesign needed, not as-built)
  const desNotify=hasPermitReject&&!hasDesign;

  // --- NEM: Yellow=Submitted, Green=Approved, Grey=Not submitted, Grey+red badge=NEM rejected ---
  const nemApproved=getVal(rec,f.msNEM); const hasNemApproved=nemApproved&&nemApproved!==''&&nemApproved!=='-';
  const nemSub=getVal(rec,f.nemSubmitted); const hasNemSub=nemSub&&nemSub!==''&&nemSub!=='-';
  const nemRej=getVal(rec,f.nemRejected); const hasNemRej=nemRej&&nemRej!==''&&nemRej!=='-';
  let nemCls='not';
  if(hasNemApproved) nemCls='done';
  else if(hasNemSub) nemCls='active';
  const nemNotify=hasNemRej&&!hasNemApproved;

  // --- Permit: Yellow=Submitted, Green=Approved, Grey=Not submitted, Grey+red badge=Permit rejected ---
  const permitApproved=getVal(rec,f.msPermit); const hasPermitApproved=permitApproved&&permitApproved!==''&&permitApproved!=='-';
  const permitSub=getVal(rec,f.permitSubmitted); const hasPermitSub=permitSub&&permitSub!==''&&permitSub!=='-';
  const hasPermitRej=hasPermitReject; // already computed for design
  let permitCls='not';
  if(hasPermitApproved) permitCls='done';
  else if(hasPermitSub) permitCls='active';
  const permitNotify=hasPermitRej&&!hasPermitApproved;

  // --- Install: Blue=Scheduled, Green=Completed, Purple=Past scheduled not completed, Grey=Not scheduled ---
  const installSched=getVal(rec,f.installScheduled); const hasInstSched=installSched&&installSched!==''&&installSched!=='-';
  const installComp=getVal(rec,f.msInstall); const hasInstComp=installComp&&installComp!==''&&installComp!=='-';
  let instCls='not';
  if(hasInstComp) instCls='done';
  else if(hasInstSched&&new Date(installSched+'T23:59:59')<now) instCls='overdue';
  else if(hasInstSched) instCls='scheduled';

  // --- Inspection: Blue=Scheduled, Green=Passed, Red=Failed, Purple=Past no disposition ---
  const inspSched=getVal(rec,f.inspectionScheduled); const hasInspSched=inspSched&&inspSched!==''&&inspSched!=='-';
  const inspPassed=getVal(rec,f.passingInspection); const hasInspPassed=inspPassed&&inspPassed!==''&&inspPassed!=='-';
  // For failed: inspection scheduled is past, not passed (simplified — no explicit fail field)
  let inspCls='not';
  if(hasInspPassed) inspCls='done';
  else if(hasInspSched&&new Date(inspSched+'T23:59:59')<now) inspCls='overdue'; // purple: past, no pass/fail yet
  else if(hasInspSched) inspCls='scheduled';

  // --- PTO: Yellow=Submitted, Green=Approved, Grey=Not submitted, Grey+red badge=PTO blocker ---
  const ptoApproved=getVal(rec,f.msPTO); const hasPtoApproved=ptoApproved&&ptoApproved!==''&&ptoApproved!=='-';
  const ptoSub=getVal(rec,f.ptoSubmitted); const hasPtoSub=ptoSub&&ptoSub!==''&&ptoSub!=='-';
  let ptoCls='not';
  if(hasPtoApproved) ptoCls='done';
  else if(hasPtoSub) ptoCls='active';
  // PTO blocker: inspection not passed and install is done (PTO can't proceed)
  const ptoNotify=hasInstComp&&!hasInspPassed&&!hasPtoApproved;

  // === BUILD HTML ===
  let html='<div class="progress-tracker"><div class="progress-tracker-inner">';
  // KCA
  html+=`<div class="pt-step ${kcaCls}"><div class="pt-dot"></div><div class="pt-label">KCA</div></div>`;
  html+=`<div class="pt-connector ${kcaCls==='done'?'done':''}"></div>`;
  // Survey
  html+=`<div class="pt-step ${ssCls}"><div class="pt-dot"></div><div class="pt-label">SS</div></div>`;
  html+=`<div class="pt-connector ${hasSurveyApproved?'done':''}"></div>`;
  // Design
  html+=`<div class="pt-step ${desCls}"><div class="pt-dot">${desNotify?'<span class="pt-notify"></span>':''}</div><div class="pt-label">Des</div></div>`;
  html+=`<div class="pt-connector ${hasDesign?'done':''}"></div>`;
  // NEM
  html+=`<div class="pt-step ${nemCls}"><div class="pt-dot">${nemNotify?'<span class="pt-notify"></span>':''}</div><div class="pt-label">NEM</div></div>`;
  html+=`<div class="pt-connector ${hasNemApproved?'done':''}"></div>`;
  // Permit
  html+=`<div class="pt-step ${permitCls}"><div class="pt-dot">${permitNotify?'<span class="pt-notify"></span>':''}</div><div class="pt-label">Perm</div></div>`;
  html+=`<div class="pt-connector ${hasPermitApproved?'done':''}"></div>`;
  // Install
  html+=`<div class="pt-step ${instCls}"><div class="pt-dot"></div><div class="pt-label">Inst</div></div>`;
  html+=`<div class="pt-connector ${hasInstComp?'done':''}"></div>`;
  // Inspection
  html+=`<div class="pt-step ${inspCls}"><div class="pt-dot"></div><div class="pt-label">Insp</div></div>`;
  html+=`<div class="pt-connector ${hasInspPassed?'done':''}"></div>`;
  // PTO
  html+=`<div class="pt-step ${ptoCls}"><div class="pt-dot">${ptoNotify?'<span class="pt-notify"></span>':''}</div><div class="pt-label">PTO</div></div>`;
  html+='</div></div>'; return html;
}

