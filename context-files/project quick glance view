/* ===== PERSONALIZED GREETING ===== */
var detectedUserName = '';
var detectedUserId = '';

function getTimeGreeting() {
  var h = new Date().getHours();
  if (h < 12) return 'Good morning';
  if (h < 17) return 'Good afternoon';
  return 'Good evening';
}

function detectCurrentUser() {
  return fetch('https://' + CONFIG.realm + '/db/main?a=API_GetUserInfo&fmt=structured', {
    method: 'GET', credentials: 'include'
  })
  .then(function(resp) {
    if (!resp.ok) throw new Error('Not in QB context');
    return resp.text();
  })
  .then(function(xml) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(xml, 'text/xml');
    var errcode = doc.querySelector('errcode');
    if (errcode && errcode.textContent !== '0') throw new Error('QB auth error');
    var userEl = doc.querySelector('user');
    if (userEl && userEl.getAttribute('id')) {
      detectedUserId = userEl.getAttribute('id');
    }
    var firstName = doc.querySelector('firstName');
    if (firstName && firstName.textContent.trim()) {
      detectedUserName = firstName.textContent.trim();
      document.getElementById('headerGreeting').textContent = getTimeGreeting() + ', ' + detectedUserName;
    }
  })
  .catch(function(e) {
    console.log('User detect skipped: ' + e.message);
    document.getElementById('headerGreeting').textContent = getTimeGreeting();
  });
}

function updateContextualSubtitle() {
  // After data loads, show not-submitted count in subtitle
  if (!cachedArrivyData || !cachedArrivyData.data) return;
  var f = cachedArrivyData.f;
  var notSubmitted = 0;
  cachedArrivyData.data.forEach(function(t) {
    var st = (getVal(t, f.status) || '').toLowerCase();
    var isComplete = st === 'complete' || st === 'site work complete';
    var submitted = getVal(t, f.submitted);
    if (isComplete && !submitted) notSubmitted++;
  });

  var dateEl = document.getElementById('dateDisplay');
  var dateText = fmtDateRange();

  if (notSubmitted > 0) {
    dateEl.innerHTML = dateText + ' &middot; <span style="color:#ef4444;font-weight:600">' + notSubmitted + ' not submitted</span>';
  } else {
    dateEl.textContent = dateText;
  }
}

function loadOverdueTicketBadge() {
  var today = new Date();
  var todayStr = today.getFullYear()+'-'+String(today.getMonth()+1).padStart(2,'0')+'-'+String(today.getDate()).padStart(2,'0');
  // Count open tickets where due date < today, not self-assigned, not complete/closed
  fetch('https://api.quickbase.com/v1/records/query', {
    method: 'POST',
    headers: { 'QB-Realm-Hostname': CONFIG.realm, 'Authorization': 'QB-USER-TOKEN ' + getToken(), 'Content-Type': 'application/json' },
    body: JSON.stringify({
      from: 'bstdqwrkg',
      select: [3],
      where: "{'91'.XEX.'Completed'}AND{'91'.XEX.'Closed'}AND{'91'.XEX.'Complete'}AND{'166'.XEX.'true'}AND{'95'.OBF.'" + todayStr + "'}",
      options: { top: 500 }
    })
  })
  .then(function(r) { return r.json(); })
  .then(function(json) {
    var count = (json.data || []).length;
    var badge = document.getElementById('ticketBadge');
    if (badge && count > 0) {
      badge.textContent = count;
      badge.style.display = 'inline-flex';
    }
  })
  .catch(function() {});
}

async function init() {
  detectCurrentUser();
  loadOverdueTicketBadge();
  const restored = restoreFilterState();
  if (!restored) {
    setDatePreset('today',document.querySelector('.date-shortcut'));
  }
  document.getElementById('dateDisplay').textContent=fmtDateRange();
  // Restore KPI tab selection
  if (activeKPI !== 'sales') {
    document.querySelectorAll('.kpi-chip').forEach(c => c.classList.remove('selected'));
    const chip = document.querySelector(`.kpi-chip[data-kpi="${activeKPI}"]`);
    if (chip) chip.classList.add('selected');
    document.querySelectorAll('.view-panel').forEach(p => p.classList.remove('active'));
    const panel = document.getElementById('panel-' + activeKPI);
    if (panel) panel.classList.add('active');
  }
  renderQuickFilters(activeKPI);
  try {
    await discoverFields();
    // Load filter options first so dropdowns are populated before restoring values
    await loadFilterOptions();
    // Re-apply saved dropdown values after options are populated
    if (restored) {
      try {
        const s = JSON.parse(sessionStorage.getItem(SESSION_KEY));
        if (s.office) document.getElementById('filterOffice').value = s.office;
        if (s.state) document.getElementById('filterState').value = s.state;
        if (s.status) document.getElementById('filterStatus').value = s.status;
        if (s.closer) document.getElementById('filterCloser').value = s.closer;
        if (s.setter) document.getElementById('filterSetter').value = s.setter;
      } catch(e) {}
    }
    await loadAllData();
  }
  catch(err) { hideLoading(); showError('Connection failed.'); console.error(err); }
}
init();

