// lateStatusByTask: taskRid → {type, timestamp, scheduled, message} — tracks if task WAS ever late (for metrics)
// currentArrivyStatus: taskRid → current arrivy status string (for badge visibility)
var lateStatusByTask = {};
var currentArrivyStatus = {};

async function loadLateStatuses(arrivyData) {
  if (!arrivyData || !arrivyData.data || !arrivyData.data.length) return;
  const f = arrivyData.f;
  // Build current status lookup and collect task/project RIDs
  const taskRids = new Set();
  const taskToProj = {};
  arrivyData.data.forEach(r => {
    const rid = String(getVal(r, 3) || '');
    const projRid = String(getVal(r, f.relatedProject) || '');
    if (rid) {
      taskRids.add(rid);
      taskToProj[rid] = projRid;
      currentArrivyStatus[rid] = (getVal(r, f.status) || '').toLowerCase().replace(/\s+/g, '');
      taskTemplateByRid[rid] = (getVal(r, f.template) || '').toLowerCase();
    }
  });
  if (!taskRids.size) return;

  const logF = {
    relatedProject: fid('arrivyTaskLog', 'Related Task (Calc) - Related Project') || 193,
    relatedTask: fid('arrivyTaskLog', 'Related Task (Calc)') || 94,
    eventType: fid('arrivyTaskLog', 'event_type') || 76,
    eventSubType: fid('arrivyTaskLog', 'event_sub_type') || 77,
    eventMessage: fid('arrivyTaskLog', 'event_message') || 74,
    timestamp: fid('arrivyTaskLog', 'time_of_event') || 79,
    scheduled: 17,
    statusTitle: fid('arrivyTaskLog', 'status_title') || 24
  };
  const sel = [3, ...Object.values(logF)].filter((v, i, a) => Boolean(v) && a.indexOf(v) === i);

  const projRids = [...new Set(Object.values(taskToProj).filter(Boolean))];
  const allLogs = [];
  for (const projRid of projRids) {
    try {
      const where = `{${logF.relatedProject}.EX.${projRid}}`;
      const res = await apiQuery(CONFIG.tables.arrivyTaskLog, where, sel, { top: 300 });
      if (res.data) allLogs.push(...res.data);
    } catch (e) { console.warn('[Late] Log query failed for project', projRid, e.message); }
  }

  // Build lookup: worst late event per task (for metrics — "was ever late")
  const priority = { 'NO_SHOW': 3, 'NOSHOW': 3, 'LATE': 2, 'PREDICTED_LATE': 1 };
  allLogs.forEach(log => {
    const et = (getVal(log, logF.eventType) || '').toUpperCase();
    const p = priority[et];
    if (!p) return;
    const taskRid = String(getVal(log, logF.relatedTask) || '');
    if (!taskRid || !taskRids.has(taskRid)) return;
    const existing = lateStatusByTask[taskRid];
    if (existing && (priority[existing.type] || 0) >= p) return;
    const type = et === 'NO_SHOW' ? 'NOSHOW' : et;
    lateStatusByTask[taskRid] = {
      type: type,
      timestamp: getVal(log, logF.timestamp) || '',
      scheduled: getVal(log, logF.scheduled) || '',
      message: getVal(log, logF.eventMessage) || ''
    };
  });

  // Inject live badges (only for tasks currently in a late state)
  injectLateBadges();
}

// Is the task's CURRENT arrivy status still in a late state?
function isCurrentlyLate(taskRid) {
  const st = currentArrivyStatus[taskRid] || '';
  return st === 'late' || st === 'predictedlate' || st === 'predicted_late' || st === 'noshow';
}

// Is the task a survey? (only show late badges for surveys for now)
var taskTemplateByRid = {};
function isSurveyTask(taskRid) {
  return (taskTemplateByRid[taskRid] || '').includes('survey');
}

function lateLabel(type) {
  if (type === 'NOSHOW') return 'NO SHOW';
  if (type === 'LATE') return 'LATE';
  return 'PRED. LATE';
}

function lateBadgeClass(type) {
  if (type === 'NOSHOW') return 'noshow';
  if (type === 'LATE') return 'late';
  return 'predicted';
}

function lateDelta(scheduled, timestamp) {
  if (!scheduled || !timestamp) return '';
  const s = new Date(scheduled);
  const t = new Date(timestamp);
  if (isNaN(s) || isNaN(t)) return '';
  const diffMin = Math.round((t - s) / 60000);
  if (diffMin <= 0) return '';
  if (diffMin < 60) return '+' + diffMin + 'm';
  const h = Math.floor(diffMin / 60);
  const m = diffMin % 60;
  return '+' + h + 'h' + (m > 0 ? m + 'm' : '');
}

function injectLateBadges() {
  document.querySelectorAll('.arrivy-drawer-slot[data-current-rid]').forEach(slot => {
    const taskRid = slot.dataset.currentRid;
    if (!taskRid) return;
    const info = lateStatusByTask[taskRid];
    if (!info) return;
    // Only show late badges for survey tasks
    if (!isSurveyTask(taskRid)) return;
    const card = slot.closest('.record-card');
    if (!card) return;
    if (card.querySelector('.late-badge')) return;

    const stillLate = isCurrentlyLate(taskRid);
    const pillsEl = card.querySelector('.card-pills');

    if (stillLate) {
      // Active late badge — prominent, visible now
      if (pillsEl) {
        const badge = document.createElement('span');
        badge.className = 'late-badge ' + lateBadgeClass(info.type);
        badge.textContent = lateLabel(info.type);
        const delta = lateDelta(info.scheduled, info.timestamp);
        if (delta) badge.textContent += ' ' + delta;
        pillsEl.appendChild(badge);
      }
      if (info.type === 'NOSHOW') { card.classList.remove('border-blue', 'border-yellow'); card.classList.add('border-red'); }
      else { card.classList.remove('border-blue'); card.classList.add('border-orange'); }
    } else {
      // Was late but now on site / complete — subtle "was late" indicator
      if (pillsEl) {
        const badge = document.createElement('span');
        badge.className = 'late-badge was-late';
        badge.textContent = 'was late';
        pillsEl.appendChild(badge);
      }
    }
  });
}

