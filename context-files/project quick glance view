function renderIntake(intakeResult) {
  cachedIntakeData=intakeResult;
  const intakeCheckFields=[{key:'install',label:'Install Agmt'},{key:'finance',label:'Finance'},{key:'utility',label:'Utility Bill'},{key:'consumption',label:'Consumption'},{key:'surveyScheduled',label:'Survey Sched'},{key:'welcomeCall',label:'Welcome Call'},{key:'adders',label:'Adders'}];
  const intakeF=intakeResult.f;

  // Group intake events by Related Project RID → array of events sorted by date
  const intakeByProject={};
  (intakeResult.data||[]).forEach(r=>{
    const projRid=String(getVal(r,intakeF.relatedProject)||'').trim();
    if(!projRid) return;
    if(!intakeByProject[projRid]) intakeByProject[projRid]=[];
    intakeByProject[projRid].push(r);
  });
  // Sort each project's events by Date Created ascending (oldest first = left column)
  Object.values(intakeByProject).forEach(arr=>{
    arr.sort((a,b)=>(getVal(a,intakeF.date)||'').localeCompare(getVal(b,intakeF.date)||''));
  });

  // Render KCA view from SALES data (all projects in filtered date range)
  if(!cachedSalesData) return;
  const {data,f}=cachedSalesData;
  const container=document.getElementById('kcaCards');
  if(!container) return;
  if(!data.length){container.innerHTML='<div class="empty-state"><div class="empty-icon">&#128200;</div>No projects in this date range</div>';return;}

  container.innerHTML=data.map((r,idx)=>{
    const rid=getVal(r,3);
    const name=getVal(r,f.name)||'Unknown';
    const closerName=getVal(r,f.closer)||'-';
    const saleDateVal=getVal(r,f.date);
    const kw=parseFloat(getVal(r,f.kw)||0);
    const kwText=kw?kw.toFixed(1)+' kW':'';
    const days=daysSince(saleDateVal); const daysText=days!==''?`${days}d`:'';
    const intakeStatus=(getVal(r,f.intakeStatus)||'').toLowerCase();
    const kcaStatusVal=(getVal(r,f.kcaStatus)||'').toLowerCase();
    const intakeCompleted=getVal(r,f.intakeCompleted);
    const hasIntake=intakeCompleted&&intakeCompleted!==''&&intakeCompleted!=='-';

    // Determine KCA status for pill and quick filter
    const projStatusLow=(getVal(r,f.status)||'').toLowerCase();
    let kcaLabel, pillBg, pillColor, qfValue;
    if(hasIntake||intakeStatus==='complete'||intakeStatus==='approved'||kcaStatusVal==='approved') {
      kcaLabel='Approved'; pillBg='#dcfce7'; pillColor='#166534'; qfValue='Approved';
    } else if(intakeStatus.includes('reject')||kcaStatusVal.includes('reject')||projStatusLow.includes('reject')) {
      kcaLabel='Rejected'; pillBg='#fee2e2'; pillColor='#991b1b'; qfValue='Rejected';
    } else if(intakeStatus==='processing'||intakeStatus==='pending'||kcaStatusVal==='pending') {
      kcaLabel='Pending'; pillBg='#fef3c7'; pillColor='#92400e'; qfValue='Pending';
    } else {
      kcaLabel='Incomplete'; pillBg='#f1f5f9'; pillColor='#475569'; qfValue='Incomplete';
    }

    // Look up intake events by project RID
    const events=intakeByProject[String(rid)]||[];
    let checklistHtml='';
    if(events.length) {
      const attempts=events.length;
      const attemptsText=attempts+' intake event'+(attempts>1?'s':'');
      // Count rejections across latest event
      const latest=events[events.length-1];
      const latestItems=intakeCheckFields.map(cf=>{
        const raw=(getVal(latest,intakeF[cf.key])||'').trim().toLowerCase();
        return raw==='reject'||raw==='rejected';
      });
      const rejectedCount=latestItems.filter(Boolean).length;
      const doneCount=intakeCheckFields.filter(cf=>{
        const raw=(getVal(latest,intakeF[cf.key])||'').trim();
        const low=raw.toLowerCase();
        return raw!==''&&raw!=='-'&&low!=='reject'&&low!=='rejected'&&low!=='no'&&low!=='false';
      }).length;
      const summaryText=`${doneCount}/${intakeCheckFields.length}`;

      // Build grid: rows = checklist items, columns = intake events by date
      const drawerId='kcaChecklist-'+idx;
      const colHeaders=events.map(ev=>{
        const d=getVal(ev,intakeF.date);
        let short='-';
        if(d){const dt=new Date(d);if(!isNaN(dt)){short=(dt.getMonth()+1)+'/'+dt.getDate();}}
        return `<th style="min-width:32px">${short}</th>`;
      }).join('');

      const gridRows=intakeCheckFields.map(cf=>{
        const cells=events.map(ev=>{
          const raw=(getVal(ev,intakeF[cf.key])||'').trim();
          const low=raw.toLowerCase();
          const isRejected=low==='reject'||low==='rejected';
          const isDone=raw!==''&&raw!=='-'&&!isRejected&&low!=='no'&&low!=='false';
          let dotClass='missing', icon='&mdash;';
          if(isDone){dotClass='done';icon='&#10003;';}
          else if(isRejected){dotClass='rejected';icon='&#10007;';}
          return `<td><span class="kca-grid-dot ${dotClass}">${icon}</span></td>`;
        }).join('');
        return `<tr><td class="kca-grid-label">${cf.label}</td>${cells}</tr>`;
      }).join('');

      checklistHtml=`
        <div class="kca-toggle" onclick="event.stopPropagation();var cl=document.getElementById('${drawerId}');cl.classList.toggle('open');this.querySelector('.kca-toggle-arrow').classList.toggle('open');">
          <span class="kca-toggle-arrow">&#9654;</span>
          <span class="kca-toggle-label">KCA Checklist</span>
          <span class="kca-toggle-summary">${summaryText} &middot; ${attemptsText}${rejectedCount?' &middot; '+rejectedCount+' rejected':''}</span>
        </div>
        <div class="kca-checklist" id="${drawerId}">
          <table class="kca-grid">
            <thead><tr><th class="kca-grid-label"></th>${colHeaders}</tr></thead>
            <tbody>${gridRows}</tbody>
          </table>
        </div>`;
    } else {
      checklistHtml=`<div style="font-size:11px;color:var(--muted);padding:6px 0 0;">No intake events yet</div>`;
    }

    const borderClass=qfValue==='Rejected'?' border-red':qfValue==='Approved'?' border-green':'';
    return `<div class="record-card clickable${borderClass}" data-qf="${qfValue}" onclick="if(!event.target.closest('.slack-link')){window.location.href=QBSKIN_NAV.projectDetail+'#rid='+encodeURIComponent('${rid}');}">
      <div class="card-header"><div class="card-title">${escapeHtml(titleCase(name))}</div><div class="card-pills"><span class="status-pill" style="background:${pillBg};color:${pillColor}">${kcaLabel}</span></div></div>
      <div class="card-date-sub">${fmtDateTime(saleDateVal)}${kwText?' &middot; '+kwText:''}${daysText?' &middot; '+daysText:''} &middot; ${escapeHtml(closerName)}</div>
      ${checklistHtml}
      <a class="slack-link" href="#" onclick="event.preventDefault();event.stopPropagation();openSlackIntake('${escapeHtml(name.replace(/'/g,"\\'"))}');" style="display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#611f69;font-weight:600;text-decoration:none;padding:4px 0 0"><svg width="14" height="14" viewBox="0 0 24 24" fill="#611f69"><path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.124 2.521a2.528 2.528 0 0 1 2.52-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.52V8.834zm-1.271 0a2.528 2.528 0 0 1-2.521 2.521 2.528 2.528 0 0 1-2.521-2.521V2.522A2.528 2.528 0 0 1 15.166 0a2.528 2.528 0 0 1 2.521 2.522v6.312zm-2.521 10.124a2.528 2.528 0 0 1 2.521 2.52A2.528 2.528 0 0 1 15.166 24a2.528 2.528 0 0 1-2.521-2.522v-2.52h2.521zm0-1.271a2.528 2.528 0 0 1-2.521-2.521 2.528 2.528 0 0 1 2.521-2.521h6.312A2.528 2.528 0 0 1 24 15.166a2.528 2.528 0 0 1-2.522 2.521h-6.312z"/></svg>Find in Slack</a>
    </div>`;
  }).join('');
}

function getInstallEmoji(r, f) {
  if(getVal(r,f.submitted)) return '\u2705';
  if(getVal(r,f.arrived)) return '\uD83D\uDEA7';
  if(getVal(r,f.enroute)) return '\uD83D\uDE97';
  return '\u23F3';
}

function renderArrivy(d) {
  const {data,f}=d; cachedArrivyData=d;
  const groups={installs:[],surveys:[],inspections:[],service:[],other:[]};
  data.forEach(r=>{const tmpl=(getVal(r,f.template)||'').toLowerCase();if(tmpl.includes('install'))groups.installs.push(r);else if(tmpl.includes('survey'))groups.surveys.push(r);else if(tmpl.includes('inspection'))groups.inspections.push(r);else if(tmpl.includes('service'))groups.service.push(r);else groups.other.push(r);});

  // Sort each group descending
  [groups.installs,groups.surveys,groups.inspections,groups.service,groups.other].forEach(g=>g.sort((a,b)=>(getVal(b,f.date)||'').localeCompare(getVal(a,f.date)||'')));

  // Drawer — lazy-loaded on click. Shows toggle immediately, fetches data on first expand.
  function arrivyDrawerHtml(projRid, currentRid) {
    if(!projRid) return '';
    const id='drawer-'+projRid+'-'+(currentRid||'');
    return `<div class="arrivy-drawer-slot" data-project-rid="${String(projRid)}" data-current-rid="${String(currentRid||'')}" data-loaded="0">
      <div class="arrivy-drawer-toggle" onclick="event.stopPropagation();toggleArrivyDrawer(this.parentElement)">
        <span class="arrivy-drawer-label">Field Activity</span><span class="arrivy-drawer-arrow">&#9654;</span>
      </div>
      <div id="${id}" class="arrivy-drawer-content" style="display:none"></div>
    </div>`;
  }

  // KPIs — use filtered date range label
  const rangeLabel=kpiRangeLabel();
  let installKwTotal=0; groups.installs.forEach(r=>installKwTotal+=parseFloat(getVal(r,f.kw)||0));
  const kwDisplay=installKwTotal>=1000?'/ '+(installKwTotal/1000).toFixed(1)+' MW':installKwTotal>0?'/ '+Math.round(installKwTotal).toLocaleString()+' kW':'';
  document.getElementById('kpiInstall').innerHTML=groups.installs.length+' <span class="kpi-unit">'+kwDisplay+'</span>';
  document.getElementById('kpiInstallSub').textContent=groups.installs.length>0?rangeLabel:'none';
  document.getElementById('kpiSurvey').textContent=groups.surveys.length;
  document.getElementById('kpiSurveySub').textContent=groups.surveys.length>0?rangeLabel:'none';
  document.getElementById('kpiInspect').textContent=groups.inspections.length;
  document.getElementById('kpiInspectSub').textContent=groups.inspections.length>0?rangeLabel:'none';

  // Installs view — with emoji status + left-border colors
  const installContainer=document.getElementById('installCards');
  if(!groups.installs.length){installContainer.innerHTML='<div class="empty-state"><div class="empty-icon">&#128295;</div>No installs '+kpiRangeLabel()+'</div>';}
  else {
    let html='';
    groups.installs.forEach(r=>{
      const emoji=getInstallEmoji(r,f);
      const name=`${getVal(r,f.first)} ${getVal(r,f.last)}`.trim();
      const kw=parseFloat(getVal(r,f.kw)||0);
      const crew=getVal(r,f.crew)||getVal(r,f.assignedCrew)||getVal(r,f.enrouteName)||'TBA';
      const scheduledDt=getVal(r,f.date);
      const taskUrl=getVal(r,f.taskUrl);
      const installComp=(getVal(r,f.installComplete)||'').toLowerCase()==='yes';
      const submittedDt=getVal(r,f.submitted);
      const arrivyStatus=(getVal(r,f.status)||'Scheduled').trim();
      const statusLow=arrivyStatus.toLowerCase();
      const isOverdue=statusLow==='overdue';
      const isSWC=statusLow==='site work complete'||statusLow==='siteworkcomplete'||statusLow==='complete';
      const isProjectDone=installComp||isSWC;
      // Left border: installComp always wins as green; then overdue=red, submitted=yellow, enroute/onsite=blue
      let borderClass='';
      if(isProjectDone) borderClass='border-green';
      else if(isOverdue) borderClass='border-red';
      else if(submittedDt) borderClass='border-yellow';
      else if(getVal(r,f.arrived)) borderClass='border-blue';
      else if(getVal(r,f.enroute)) borderClass='border-blue';
      // Quick filter: installComp = Complete even if Arrivy says overdue
      const qfVal=isProjectDone?'Complete':isOverdue?'Overdue':submittedDt?'Submitted':getVal(r,f.arrived)?'OnSite':getVal(r,f.enroute)?'EnRoute':'Scheduled';
      // Submitted bubble: red if project is done but Arrivy form was never submitted
      const submittedCls=submittedDt?'submitted-highlight':(isProjectDone&&!submittedDt)?'missed':'off';
      // Status pill: show Install Complete if project is done regardless of Arrivy status
      const displayStatus=isProjectDone?'Complete':arrivyStatus;

      const projRid=getVal(r,f.relatedProject);
      const taskRid=getVal(r,3);
      html+=`<div class="record-card compact clickable ${borderClass}" data-qf="${qfVal}" onclick="if(!event.target.closest('.arrivy-link,.arrivy-drawer-toggle,.arrivy-drawer-content')){window.location.href=QBSKIN_NAV.projectDetail+'#rid='+encodeURIComponent('${projRid||''}');}">
        <div class="card-header" style="margin-bottom:2px">
          <div class="card-title" style="font-size:14px">${emoji} ${escapeHtml(name)}</div>
          <div class="card-pills">${statusPill(displayStatus)}</div>
        </div>
        <div class="card-date-sub" style="margin-bottom:4px">${fmtDateTime(scheduledDt)}${kw?' &middot; '+kw.toFixed(1)+' kW':''}${crew?' &middot; '+escapeHtml(crew):''}</div>
        <div class="field-status" style="margin-top:0;padding-top:0;border-top:none;gap:3px">
          <span class="fs-chip ${getVal(r,f.enroute)?'on':'off'}" style="font-size:9px;padding:2px 6px">🚗ER</span>
          <span class="fs-chip ${getVal(r,f.arrived)?'on':'off'}" style="font-size:9px;padding:2px 6px">🚧OS</span>
