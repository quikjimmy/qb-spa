// Populate Arrivy task dropdowns in Sales cards after both datasets are rendered
async function populateSalesArrivySlots(arrivyData) {
  if(!arrivyData||!arrivyData.f) return;
  const f=arrivyData.f;

  // Collect all project RIDs from the sales cards
  const slots=document.querySelectorAll('.arrivy-tasks-slot');
  const pids=new Set();
  slots.forEach(slot=>{const pid=slot.dataset.projectRid;if(pid)pids.add(pid);});
  if(!pids.size) return;

  // Query ALL arrivy tasks for these projects (no date filter)
  const pidList=[...pids];
  // QB OR query: {'6'.EX.'123'}OR{'6'.EX.'456'}...
  const chunks=[];
  for(let i=0;i<pidList.length;i+=20){chunks.push(pidList.slice(i,i+20));}
  let allTasks=[];
  for(const chunk of chunks){
    const where=chunk.map(pid=>`{'6'.EX.'${pid}'}`).join('OR');
    const sel=[3,...Object.values(f)].filter(Boolean);
    try{const res=await apiQuery(CONFIG.tables.arrivyTasks,where,sel,{top:500});allTasks=allTasks.concat(res.data||[]);}catch(e){console.warn('Arrivy slot query failed:',e);}
  }

  // Group by project
  const byProject={};
  allTasks.forEach(r=>{
    const pid=getVal(r,f.relatedProject);
    if(!pid) return;
    if(!byProject[pid]) byProject[pid]=[];
    byProject[pid].push(r);
  });
  // Sort each list chronologically (newest first)
  Object.values(byProject).forEach(arr=>arr.sort((a,b)=>(getVal(b,f.date)||'').localeCompare(getVal(a,f.date)||'')));

  // Inject into slots
  slots.forEach(slot=>{
    const pid=slot.dataset.projectRid;
    const tasks=byProject[pid];
    if(!tasks||!tasks.length) return;
    const drawerId='sales-arrivy-'+pid;
