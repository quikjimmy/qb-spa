// Cache: projectRid → array of task records (persists until page reload)
const drawerCache = {};

// Toggle drawer: first click fetches data, subsequent clicks just show/hide
async function toggleArrivyDrawer(slot) {
  if (!slot) return;
  const projRid = String(slot.dataset.projectRid || '');
  const currentRid = slot.dataset.currentRid || '';
  const contentEl = slot.querySelector('.arrivy-drawer-content');
  const arrowEl = slot.querySelector('.arrivy-drawer-arrow');
  const labelEl = slot.querySelector('.arrivy-drawer-label');
  if (!contentEl) return;

  // If already loaded, just toggle visibility
  if (slot.dataset.loaded === '1') {
    const isOpen = contentEl.style.display !== 'none';
    contentEl.style.display = isOpen ? 'none' : 'block';
    if (arrowEl) arrowEl.classList.toggle('open', !isOpen);
    return;
  }

  // First click — fetch data
  if (labelEl) labelEl.textContent = 'Loading...';

  try {
    let tasks;
    if (drawerCache[projRid]) {
      tasks = drawerCache[projRid];
    } else {
      // Use cached arrivy field map from the last loadArrivy() call
      const f = cachedArrivyData.f;
      const sel = [3, ...Object.values(f)].filter((v, i, a) => Boolean(v) && a.indexOf(v) === i);
      const where = `{${f.relatedProject}.EX.${projRid}}`;
      const res = await apiQuery(CONFIG.tables.arrivyTasks, where, sel, { top: 200 });
      tasks = (res.data || []).sort((a, b) => (getVal(a, f.date) || '').localeCompare(getVal(b, f.date) || ''));
      drawerCache[projRid] = tasks;
    }

    const f = cachedArrivyData.f;

    if (!tasks.length) {
      if (labelEl) labelEl.textContent = 'No field activity';
      slot.dataset.loaded = '1';
      return;
    }

    // Render rows with late status indicators
    const rows = tasks.map(t => {
      const rid = getVal(t, 3);
      const ridStr = String(rid);
      const tmpl = getVal(t, f.template) || 'Task';
      const dt = getVal(t, f.date);
      const crew = getVal(t, f.crew) || getVal(t, f.assignedCrew) || getVal(t, f.enrouteName) || '';
      const st = (getVal(t, f.status) || 'Scheduled').trim();
      const stLow = st.toLowerCase();
      const isCurrent = String(rid) === String(currentRid);
      const rawLateInfo = lateStatusByTask[ridStr];
      const lateInfo = (rawLateInfo && isSurveyTask(ridStr)) ? rawLateInfo : null;
      const stillLate = lateInfo && isCurrentlyLate(ridStr);
      let dotColor = '#94a3b8';
      if (stillLate) dotColor = lateInfo.type === 'PREDICTED_LATE' ? '#f59e0b' : '#ef4444';
      else if (stLow === 'complete' || stLow === 'site work complete') dotColor = '#10b981';
      else if (stLow === 'overdue') dotColor = '#ef4444';
      else if (getVal(t, f.submitted)) dotColor = '#f59e0b';
      else if (getVal(t, f.arrived)) dotColor = '#3b82f6';
      else if (getVal(t, f.enroute)) dotColor = '#3b82f6';
      const rowClass = (lateInfo && stillLate) ? 'arrivy-drawer-row late-event' : 'arrivy-drawer-row';
      const highlight = (!(lateInfo && stillLate) && isCurrent) ? ' style="background:#f0f9ff;border-radius:6px;padding:2px 4px;margin:-2px -4px"' : '';
      const fmtDt = dt ? new Date(dt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'TBD';
      const dRtr = (getVal(t, f.rtrStatus) || '').trim().toLowerCase();
      const rtrDotColor = dRtr.includes('pass') ? '#10b981' : dRtr.includes('fail') ? '#ef4444' : dRtr ? '#f59e0b' : '#cbd5e1';
      const rtrDotTitle = dRtr ? dRtr : 'No RTR data';
      const rtrDot = `<span style="width:6px;height:6px;border-radius:50%;background:${rtrDotColor};display:inline-block;margin-left:2px" title="${rtrDotTitle}"></span>`;
      let lateHtml = '';
      if (lateInfo && stillLate) {
        const delta = lateDelta(lateInfo.scheduled, lateInfo.timestamp);
        lateHtml = `<span class="late-delta">${lateLabel(lateInfo.type)}${delta ? ' ' + delta : ''}</span>`;
      } else if (lateInfo && !stillLate) {
        lateHtml = `<span class="late-delta" style="color:#94a3b8;font-weight:500">was late</span>`;
      }
      return `<div class="${rowClass}"${highlight}><span class="arrivy-drawer-dot" style="background:${dotColor}"></span><span class="arrivy-drawer-tmpl">${escapeHtml(tmpl.length > 22 ? tmpl.slice(0, 20) + '\u2026' : tmpl)}${rtrDot}</span><span class="arrivy-drawer-date">${fmtDt}</span>${crew ? `<span class="arrivy-drawer-crew">${escapeHtml(crew.split(' ')[0])}</span>` : ''}${lateHtml}</div>`;
    }).join('');

    contentEl.innerHTML = rows;
    contentEl.style.display = 'block';
    if (labelEl) labelEl.textContent = 'Field Activity (' + tasks.length + ')';
    if (arrowEl) arrowEl.classList.add('open');
    slot.dataset.loaded = '1';
  } catch (e) {
    console.error('[Drawer] Failed to load project', projRid, ':', e.message || e);
    if (labelEl) labelEl.textContent = 'Field Activity (error)';
  }
}

// Check survey dispositions — query ArrivyTaskLog for overdue surveys to detect cancel/reschedule
// Uses Related Task (Calc) - Related Project (FID 193) to query by project RID (proven to work)
async function checkSurveyDispositions(arrivyData) {
  try {
    const {data, f} = arrivyData;
    // Find survey tasks that show as overdue
    const overdueSurveys = data.filter(r => {
      const tmpl = (getVal(r, f.template) || '').toLowerCase();
      const st = (getVal(r, f.status) || '').toLowerCase();
      return tmpl.includes('survey') && st === 'overdue';
    });
    if (!overdueSurveys.length) { console.log('[Disposition] No overdue surveys found'); return; }
    console.log('[Disposition] Found', overdueSurveys.length, 'overdue survey(s), checking ArrivyTaskLog...');

    // Build map: projectRid → [arrivyTaskRid, ...] for overdue surveys
    const projToTasks = {};
    overdueSurveys.forEach(r => {
      const projRid = String(getVal(r, f.relatedProject) || '');
      const taskRid = String(getVal(r, 3) || '');
      if (!projRid || !taskRid) return;
      if (!projToTasks[projRid]) projToTasks[projRid] = [];
      projToTasks[projRid].push(taskRid);
    });
    const projRids = Object.keys(projToTasks);
    if (!projRids.length) return;

    // ArrivyTaskLog field IDs — use exact labels, hardcode fallbacks from known field map
    const logF = {
      relatedProject: fid('arrivyTaskLog', 'Related Task (Calc) - Related Project') || 193,
      relatedTask: fid('arrivyTaskLog', 'Related Task (Calc)') || 94,
      statusTitle: fid('arrivyTaskLog', 'status_title') || 24,
      eventType: fid('arrivyTaskLog', 'event_type') || 76,
      eventSubType: fid('arrivyTaskLog', 'event_sub_type') || 77,
      eventTitle: fid('arrivyTaskLog', 'event_title') || 73,
      eventMessage: fid('arrivyTaskLog', 'event_message') || 74,
      arrivyStatusNotes: fid('arrivyTaskLog', 'Arrivy Input: Status Notes') || 127,
      arrivyStatusTitle: fid('arrivyTaskLog', 'Arrivy Input: Status Title') || 124,
      template: fid('arrivyTaskLog', 'template') || 50
    };
    console.log('[Disposition] Resolved log FIDs:', JSON.stringify(logF));

    const sel = [3, ...Object.values(logF)].filter((v, i, a) => Boolean(v) && a.indexOf(v) === i);

    // Query one project at a time using Related Project (numeric, FID 193) — same pattern as drawer
    const allLogs = [];
    for (const projRid of projRids) {
      const where = `{${logF.relatedProject}.EX.${projRid}}`;
      try {
        const res = await apiQuery(CONFIG.tables.arrivyTaskLog, where, sel, { top: 300 });
        const count = res.data ? res.data.length : 0;
        console.log('[Disposition] Project', projRid, ':', count, 'log entries');
        if (res.data) allLogs.push(...res.data);
      } catch (e) {
        console.warn('[Disposition] FAILED project', projRid, ':', e.message || e, '| WHERE:', where);
      }
    }

    if (!allLogs.length) { console.log('[Disposition] No log entries found'); return; }
    console.log('[Disposition] Total log entries:', allLogs.length);

    // Group log entries by Related Task RID (the ArrivyTask record)
    const logsByTask = {};
    allLogs.forEach(log => {
      const taskRid = String(getVal(log, logF.relatedTask) || '');
      if (!taskRid) return;
      if (!logsByTask[taskRid]) logsByTask[taskRid] = [];
      logsByTask[taskRid].push(log);
    });

    // Scan each overdue survey's log entries for cancel/reschedule keywords
    const cancelPattern = /cancel/i;
    const reschedPattern = /reschedul/i;
    const dispositions = {}; // arrivyTaskRid → 'cancelled' | 'rescheduled'

    // Check logs for each overdue survey task
    for (const projRid of projRids) {
      const taskRids = projToTasks[projRid];
      for (const taskRid of taskRids) {
        const logs = logsByTask[taskRid];
        if (!logs || !logs.length) {
          console.log('[Disposition] Task', taskRid, '(project', projRid, '): no log entries');
          continue;
        }
        let disposition = null;
        for (const log of logs) {
          const combined = [
            getVal(log, logF.statusTitle),
            getVal(log, logF.eventType),
            getVal(log, logF.eventSubType),
            getVal(log, logF.eventTitle),
            getVal(log, logF.eventMessage),
            getVal(log, logF.arrivyStatusNotes),
            getVal(log, logF.arrivyStatusTitle)
          ].join(' ');
          if (cancelPattern.test(combined)) { disposition = 'cancelled'; break; }
          if (reschedPattern.test(combined)) { disposition = 'rescheduled'; break; }
        }
        console.log('[Disposition] Task', taskRid, ':', disposition || 'no cancel/reschedule found', '(' + logs.length + ' log entries)');
        if (disposition) dispositions[taskRid] = disposition;
      }
    }

    console.log('[Disposition] Results:', JSON.stringify(dispositions));
    if (!Object.keys(dispositions).length) return;

    // Update survey cards in the DOM
    const surveyCards = document.querySelectorAll('#surveyCards .record-card');
    surveyCards.forEach(card => {
      const slot = card.querySelector('.arrivy-drawer-slot');
      if (!slot) return;
      const currentRid = slot.dataset.currentRid;
      if (!currentRid || !dispositions[currentRid]) return;

      const disp = dispositions[currentRid];
      const isCancel = disp === 'cancelled';
      const label = isCancel ? 'Cancelled' : 'Rescheduled';
      const emoji = isCancel ? '\uD83D\uDEAB' : '\uD83D\uDD04';

      // Update status pill
      const pill = card.querySelector('.status-pill');
      if (pill) {
        pill.textContent = label;
        pill.className = 'status-pill';
        pill.style.background = isCancel ? '#fef2f2' : '#fffbeb';
        pill.style.color = isCancel ? '#991b1b' : '#92400e';
      }

      // Update border color
      card.classList.remove('border-red', 'border-orange', 'border-green', 'border-yellow', 'border-blue');
      card.classList.add(isCancel ? 'border-muted' : 'border-orange');

      // Update the title emoji
      const titleEl = card.querySelector('.card-title');
      if (titleEl) {
        titleEl.innerHTML = titleEl.innerHTML.replace(/^[\u2705\u23F3\uD83D\uDE97\uD83D\uDEA7\uD83D\uDEAB\uD83D\uDD04]/, emoji);
      }

      // Update quick-filter data attribute
      card.dataset.qf = isCancel ? 'Cancelled' : 'Rescheduled';
    });

    // Add Cancelled/Rescheduled to quick filter chips if any found
    const hasCancel = Object.values(dispositions).some(d => d === 'cancelled');
    const hasResched = Object.values(dispositions).some(d => d === 'rescheduled');
    if (hasCancel || hasResched) {
      const existing = QUICK_FILTER_CONFIG.surveys.map(sf => sf.value);
      if (hasCancel && !existing.includes('Cancelled')) {
        QUICK_FILTER_CONFIG.surveys.push({ label: '\uD83D\uDEAB Cancel', value: 'Cancelled' });
      }
      if (hasResched && !existing.includes('Rescheduled')) {
        QUICK_FILTER_CONFIG.surveys.push({ label: '\uD83D\uDD04 Resched', value: 'Rescheduled' });
      }
      if (activeKPI === 'surveys') renderQuickFilters('surveys');
    }
  } catch (err) {
    console.warn('[Disposition] Check failed:', err.message || err);
  }
}

