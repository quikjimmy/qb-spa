      const st=(getVal(t,f.status)||'Scheduled').trim();
      const stLow=st.toLowerCase();
      let dotColor='#94a3b8';
      if(stLow==='complete'||stLow==='site work complete') dotColor='#10b981';
      else if(stLow==='overdue') dotColor='#ef4444';
      else if(getVal(t,f.submitted)) dotColor='#f59e0b';
      else if(getVal(t,f.arrived)||getVal(t,f.enroute)) dotColor='#3b82f6';
      const fmtDt=dt?new Date(dt).toLocaleDateString('en-US',{month:'short',day:'numeric'}):'TBD';
      return `<div class="arrivy-drawer-row"><span class="arrivy-drawer-dot" style="background:${dotColor}"></span><span class="arrivy-drawer-tmpl">${escapeHtml(tmpl.length>22?tmpl.slice(0,20)+'…':tmpl)}</span><span class="arrivy-drawer-date">${fmtDt}</span>${crew?`<span class="arrivy-drawer-crew">${escapeHtml(crew.split(' ')[0])}</span>`:''}</div>`;
