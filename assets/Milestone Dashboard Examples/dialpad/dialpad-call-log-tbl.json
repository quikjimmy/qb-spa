      "formula": "var number age = ToMSeconds(Now()-[Event Timestamp (Date/Time)]);\r\n\r\nIf([direction]=\"inbound\",\r\n\"<span style='display:none;'>\" & Right(\"000000000000\" & ToText(Int($age)), 12) & \"</span>\" &\r\n\"<div style='width: 100%; box-sizing: border-box;'>\" &\r\n  \"<div style='background-color: #E9E9EB; color: black; padding: 4px 8px; border-radius: 10px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 12px; line-height: 1.4; overflow: hidden;'>\" &\r\n    If([duration]>0,\r\n      ToText(Int([duration]/60000)) & \"m \" & ToText(Mod(Int([duration]/1000),60)) & \"s\",\r\n      \"0s\") &\r\n    \" · \" & [call_state] &\r\n    \"<div style='font-size: 9px; opacity: 0.6; text-align: right;'>\" & ToTimestamp([event_timestamp_unix]) & \"</div>\" &\r\n  \"</div>\" &\r\n  If([recording_details.url]<>\"\",\r\n    \"<div style='margin-top: 4px;'><audio controls controlslist='nodownload noplaybackrate' preload='none' style='width: 100%; height: 36px;'><source src='\" & [recording_details.url] & \"' type='audio/mpeg' /></audio></div>\",\r\n    \"\") &\r\n  If([voicemail_share_link]<>\"\" and [recording_details.url]=\"\",\r\n    \"<div style='margin-top: 4px;'><a href='\" & [voicemail_share_link] & \"' target='_blank' style='color: #007AFF; text-decoration: underline; font-size: 12px;'>Voicemail</a></div>\",\r\n    \"\") &\r\n\"</div>\",\r\nIf([direction]=\"outbound\",\r\n\"<span style='display:none;'>\" & Right(\"000000000000\" & ToText(Int($age)), 12) & \"</span>\" &\r\n\"<div style='width: 100%; box-sizing: border-box;'>\" &\r\n  \"<div style='background-color: #007AFF; color: white; padding: 4px 8px; border-radius: 10px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 12px; line-height: 1.4; overflow: hidden;'>\" &\r\n    If([duration]>0,\r\n      ToText(Int([duration]/60000)) & \"m \" & ToText(Mod(Int([duration]/1000),60)) & \"s\",\r\n      \"0s\") &\r\n    \" · \" &[call_state] &\r\n    \"<div style='font-