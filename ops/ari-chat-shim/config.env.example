# /etc/ari-chat-shim/config.env  (chmod 600, root-owned)
#
# ARI_SHIM_TOKEN must be byte-for-byte identical to the value qb-spa's
# Railway service sends as ARI_SHIM_TOKEN. That's the only auth between them.

ARI_SHIM_TOKEN=3c03b460bcf5ff4ddccf4506e48cd662a0c5c892c798680
ARI_SHIM_BIND=127.0.0.1:18790
ARI_SHIM_CLAUDE_BIN=/usr/bin/claude
ARI_SHIM_TIMEOUT_SEC=300

# workspace name → cwd. Add eng/finance/sales/marketing as those agents land.
ARI_SHIM_WORKSPACES_JSON={"coord":"/root/.openclaw/workspace-coord"}
