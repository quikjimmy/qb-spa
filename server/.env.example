QB_REALM_HOSTNAME=kin.quickbase.com
QB_USER_TOKEN=your-quickbase-user-token-here
JWT_SECRET=change-me-to-a-random-secret
PORT=3001

# Arrivy REST API — used to inline surveyor photos + cancellation reason
# in the cancelled-event detail panel. Generate at:
#   https://app.arrivy.com/settings/api_info
# Optional: ARRIVY_API_BASE (defaults to https://app.arrivy.com/api)
ARRIVY_AUTH_KEY=
ARRIVY_AUTH_TOKEN=

# Optional: shared secret for the /api/webhooks/arrivy ingest. When set,
# Arrivy must include either:
#   X-Arrivy-Token: <this value>      (literal token match), OR
#   X-Arrivy-Signature: <hex>          (HMAC-SHA256 of body, secret)
# Leave blank during initial wire-up so Arrivy's "send test" works
# without coordination; tighten once traffic is flowing.
ARRIVY_WEBHOOK_SECRET=
