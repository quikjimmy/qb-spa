QB_REALM_HOSTNAME=kin.quickbase.com
QB_USER_TOKEN=your-quickbase-user-token-here
JWT_SECRET=change-me-to-a-random-secret
PORT=3001

# QuickBase MCP server — when QB_MCP_URL is set, the chatbot route exposes
# the MCP server's tools to every chat thread. Leave blank to disable.
#
# Railway prod: use the private-network hostname so traffic never leaves
# the project. The MCP service is named "QB_MCP"; Railway's internal DNS
# is lowercased.
#   QB_MCP_URL=http://qb-mcp.railway.internal:8080/mcp
# Local dev: run the MCP server on :8080 and point at it directly.
#   QB_MCP_URL=http://localhost:8080/mcp
# Public fallback (only if the internal DNS doesn't resolve — e.g. testing
# from your laptop against the deployed service):
#   QB_MCP_URL=https://<your-qb-mcp-host>/mcp
#
# QB_MCP_TOKEN must match MCP_SHARED_SECRET on the MCP service. The MCP
# server's BearerAuthMiddleware 401s any request without it.
QB_MCP_URL=
QB_MCP_TOKEN=

# Arrivy REST API — used to inline surveyor photos + cancellation reason
# in the cancelled-event detail panel. Generate at:
#   https://app.arrivy.com/settings/api_info
# Optional: ARRIVY_API_BASE (defaults to https://app.arrivy.com/api)
ARRIVY_AUTH_KEY=
ARRIVY_AUTH_TOKEN=

# Optional: shared secret for the /api/webhooks/arrivy ingest. When set,
# Arrivy must include either:
#   X-Arrivy-Token: <this value>      (literal token match), OR
#   X-Arrivy-Signature: <hex>          (HMAC-SHA256 of body, secret)
# Leave blank during initial wire-up so Arrivy's "send test" works
# without coordination; tighten once traffic is flowing.
ARRIVY_WEBHOOK_SECRET=

# OpenClaw runtime adapter — optional. When OPENCLAW_BASE_URL is set,
# production tasks with runtime=openclaw POST their bounded work packet here.
# The endpoint should return the normalized contract described in:
#   docs/openclaw-governance-adapter.md
OPENCLAW_BASE_URL=
OPENCLAW_RUN_PATH=/api/agent-runs
OPENCLAW_API_KEY=
OPENCLAW_AUTH_HEADER=Authorization
OPENCLAW_AUTH_SCHEME=Bearer
OPENCLAW_TIMEOUT_MS=120000

# Optional: force the legacy local shim for mapped OpenClaw-ready workflows.
# Leave unset in production once the VPS adapter is ready.
OPENCLAW_LOCAL_SHIM=

# Optional: override role slug/name -> OpenClaw agent labels.
# Example: {"pc-inspection-pto-worker":"coordinator","ari-pc-manager":"coordinator"}
OPENCLAW_AGENT_LABELS_JSON=
