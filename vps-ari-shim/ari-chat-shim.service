[Unit]
Description=ari-chat-shim — HTTP wrapper around `claude --print` for qb-spa
After=network-online.target openclaw.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/ari-chat-shim
ExecStart=/usr/bin/python3 /opt/ari-chat-shim/server.py
EnvironmentFile=/etc/ari-chat-shim/config.env
Restart=always
RestartSec=5
# Hardening — none of the legacy Python services on this box use these, but
# this service spawns subprocesses with the user's identity in env, so we
# tighten what we can without breaking the claude binary.
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true

[Install]
WantedBy=multi-user.target
