# Copy to /etc/ari-chat-shim/config.env (mode 0600, owned by root) and fill in.

# Shared bearer token. Must match ARI_SHIM_TOKEN on the qb-spa Railway service.
# Generate fresh: openssl rand -hex 32
ARI_SHIM_TOKEN=

# Bind address. Caddy already reverse-proxies ai.kinhome.com/api/agent-runs/*
# to localhost:18790 with a 320s read_timeout — match here unless changing both.
ARI_SHIM_BIND=127.0.0.1:18790

# JSON map of workspace name → cwd. Workspace names are the public-facing
# identifier qb-spa sends; cwd is where `claude --print` runs (Ari's
# OpenClaw workspace dir). Add more workspaces as more agents go live.
ARI_SHIM_WORKSPACES_JSON={"coord":"/root/.openclaw/workspace-coord"}

# Path to the Claude Code CLI binary.
ARI_SHIM_CLAUDE_BIN=/usr/bin/claude

# Per-request timeout for the claude subprocess. The Caddy read_timeout for
# /api/agent-runs/* is 320s, so keep this below that to surface our own
# timeout error (502 with a clear message) instead of Caddy's 504.
ARI_SHIM_TIMEOUT_SEC=300
